---
import BaseLayout from '@/layouts/BaseLayout.astro';

// The 6 tiers — copy stays in sync with tokenjam/cli/cmd_tokenmaxx.py.
// Primary classifier is the multiplier vs the user's plan fee; absolute
// USD/mo thresholds are an API-user fallback calibrated against Max-5x
// ($100/mo). If the CLI thresholds or quips change, update both.
const tiers = [
  { emoji: '💧',     label: 'TokenSipper',      range: '< 1× plan',      apiFallback: '< $100/mo',        quip: 'Are you even using AI?' },
  { emoji: '🥱',     label: 'TokenModerator',   range: '1× – 4× plan',   apiFallback: '$100 – $400/mo',   quip: 'Mostly reasonable. Try harder.' },
  { emoji: '💸',     label: 'TokenMaxxer',      range: '4× – 10× plan',  apiFallback: '$400 – $1,000/mo', quip: 'You\'re paying Anthropic\'s rent.' },
  { emoji: '🔥',     label: 'TokenSuperMaxxer', range: '10× – 20× plan', apiFallback: '$1,000 – $2,000/mo', quip: 'You\'re paying their interns\' rent too.' },
  { emoji: '🔥🔥',   label: 'TokenMegaMaxxer',  range: '20× – 50× plan', apiFallback: '$2,000 – $5,000/mo', quip: 'Touch grass. Then run `tj optimize`.' },
  { emoji: '🔥🔥🔥', label: 'TokenGigaMaxxer',  range: '50×+ plan',      apiFallback: '$5,000+/mo',       quip: 'Anthropic\'s CFO knows your name.' },
];

// Three commands the tweet promises. Keep these verbatim with the social copy.
// pipx (not pip) — works on macOS Homebrew Python + Debian 12+ / Ubuntu 24+
// where PEP 668 blocks `pip install` into the system Python (issue #86).
const installLines = [
  'pipx install tokenjam',
  'tj onboard --claude-code',
  'tj tokenmaxx',
];
const installJoined = installLines.join('\n');

// Pre-filled X (twitter) share intent. Generic enough that the user can
// edit before posting; carries the @tokenjamdev mention and the page URL.
const shareText = "Just discovered my #TokenMaxx tier with @tokenjamdev. Find yours:";
const shareUrl = "https://tokenjam.dev/tokenmaxxing";
const xIntent = `https://x.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`;
---
<BaseLayout
  title="How hard are you TokenMaxxing? — TokenJam"
  description="Find out your AI token-spending tier in three commands. TokenJam reads your existing Claude Code session logs and classifies your 30-day usage into a tier from TokenSipper to TokenGigaMaxxer. Open-source, local-first, no signup."
  image="/og-image.png"
>
  <main class="tj-main">
    <article class="tmx">

      <!-- HERO -->
      <header class="tmx-hero">
        <h1 class="tmx-hero-h1">How hard are you <span class="tmx-hero-accent">TokenMaxxing</span>?</h1>
        <p class="tmx-hero-sub">
          Find out your tier in <strong>3 commands</strong>. No signup. Runs locally.
        </p>
      </header>

      <!-- INSTALL — top of page so people who came to install see it before the meme -->
      <section class="tmx-install-section">
        <div class="tmx-install-card">
          <div class="terminal tmx-install-term">
            <div class="terminal-titlebar">
              <span class="dot dot-r"></span>
              <span class="dot dot-y"></span>
              <span class="dot dot-g"></span>
              <span class="terminal-title">find out your tier</span>
            </div>
            <div class="terminal-body tmx-install-body">
              {installLines.map((cmd) => (
                <span class="tline"><span class="t-prompt">$ </span><span class="t-cmd">{cmd}</span></span>
              ))}
            </div>
          </div>
          <div class="tmx-install-ctas">
            <button class="btn-primary" id="tmx-copy-btn" data-cmd={installJoined} type="button" onclick="window.trackEvent && window.trackEvent('cta_click', 'conversion', 'tokenmaxx_copy_install')">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="4" y="4" width="8" height="8" rx="1.5"/><path d="M2 10V3a1 1 0 011-1h7"/></svg>
              <span id="tmx-copy-label">Copy 3 commands</span>
            </button>
            <a class="btn-secondary" href="https://github.com/metabuilder-labs/tokenjam" target="_blank" rel="noopener noreferrer" onclick="window.trackEvent && window.trackEvent('cta_click', 'conversion', 'tokenmaxx_view_github')">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
              View on GitHub
            </a>
          </div>
          <p class="tmx-install-trust">
            Reads your existing <code>~/.claude/projects/</code> logs · 30 days of history · MIT-licensed
          </p>
        </div>
      </section>

      <!-- SAMPLE OUTPUT — show what the screenshot will look like before
           the user installs. Verbatim rendering of the CLI Panel output
           with the same green / teal accents so the page and terminal
           feel like the same artifact. -->
      <section class="tmx-sample-section">
        <p class="tmx-sample-caption">Here's what you'll see: a real run for a Max-5x user.</p>
        <pre class="tmx-sample"><span class="tmx-sample-border">╭─ </span><span class="tmx-sample-title">TokenJam TokenMaxxing Report</span><span class="tmx-sample-border"> ─────────────────────────────────────────────╮</span>
<span class="tmx-sample-border">│                                                                              │</span>
<span class="tmx-sample-border">│</span>  🔥🔥 <span class="tmx-sample-bold">You're a TokenMegaMaxxer.</span>                                              <span class="tmx-sample-border">│</span>
<span class="tmx-sample-border">│                                                                              │</span>
<span class="tmx-sample-border">│</span>  Touch grass. Then run <span class="tmx-sample-green">tj optimize</span>.                                          <span class="tmx-sample-border">│</span>
<span class="tmx-sample-border">│                                                                              │</span>
<span class="tmx-sample-border">│</span>  <span class="tmx-sample-bold">$4056.82</span> in last 30d across <span class="tmx-sample-bold">33</span> sessions.                                    <span class="tmx-sample-border">│</span>
<span class="tmx-sample-border">│</span>  That's <span class="tmx-sample-bold">40.6×</span> your <span class="tmx-sample-bold">Max 5x plan</span> cost (<span class="tmx-sample-bold">$100/mo flat</span>).                          <span class="tmx-sample-border">│</span>
<span class="tmx-sample-border">│                                                                              │</span>
<span class="tmx-sample-border">│</span>  💡 No obvious savings flagged yet — run <span class="tmx-sample-green">tj optimize</span> for the full report     <span class="tmx-sample-border">│</span>
<span class="tmx-sample-border">│</span>  once you have more data.                                                    <span class="tmx-sample-border">│</span>
<span class="tmx-sample-border">│                                                                              │</span>
<span class="tmx-sample-border">╰──────────────────────────────────────────────────────────────────────────────╯</span>
  <span class="tmx-sample-teal">Share your tier: screenshot the above and tag </span><span class="tmx-sample-teal-bold">@tokenjamdev</span></pre>
      </section>

      <!-- SHARE-ON-X strip — moved up under the install/sample so the
           CTA is the next thing you see after "here's what you'll get."
           Brighter background + X branding + pre-filled intent URL so
           a single click composes a tweet. -->
      <section class="tmx-share-strip">
        <div class="tmx-share-inner">
          <div class="tmx-share-icon" aria-hidden="true">
            <svg viewBox="0 0 1200 1227" fill="currentColor"><path d="M714.163 519.284 1160.89 0H1055.03L667.137 450.887 357.328 0H0L468.492 681.821 0 1226.37H105.866L515.491 750.218 842.672 1226.37H1200L714.137 519.284h.026ZM569.165 687.828l-47.468-67.894-377.686-540.24h162.604l304.797 435.991 47.468 67.894 396.2 566.721H892.476L569.165 687.854v-.026Z"/></svg>
          </div>
          <div class="tmx-share-body">
            <h2>Post your tier on X.</h2>
            <p>Screenshot your output, tag <strong>@tokenjamdev</strong>, and we'll boost the best ones.</p>
          </div>
          <a
            class="tmx-share-btn"
            href={xIntent}
            target="_blank"
            rel="noopener noreferrer"
            onclick="window.trackEvent && window.trackEvent('cta_click', 'conversion', 'tokenmaxx_share_on_x')"
          >
            <svg width="14" height="14" viewBox="0 0 1200 1227" fill="currentColor" aria-hidden="true"><path d="M714.163 519.284 1160.89 0H1055.03L667.137 450.887 357.328 0H0L468.492 681.821 0 1226.37H105.866L515.491 750.218 842.672 1226.37H1200L714.137 519.284h.026ZM569.165 687.828l-47.468-67.894-377.686-540.24h162.604l304.797 435.991 47.468 67.894 396.2 566.721H892.476L569.165 687.854v-.026Z"/></svg>
            Share on X
          </a>
        </div>
      </section>

      <!-- TIER LADDER -->
      <section class="tmx-tiers-section">
        <header class="section-head">
          <h2 class="section-h2">The 6 tiers</h2>
          <p class="section-lede">
            Classification is based on <strong>how hard you're maxxing your plan</strong>:
            the multiplier between your last-30-days
            <a href="https://platform.claude.com/docs/en/docs/about-claude/pricing" target="_blank" rel="noopener noreferrer">implied API value</a>
            and your plan's flat monthly fee. Works for <strong>Pro</strong> ($20), <strong>Max-5x</strong> ($100), and <strong>Max-20x</strong> ($200) subscriptions.
          </p>
        </header>
        <ol class="tmx-tiers">
          {tiers.map((t) => (
            <li class="tmx-tier" data-tier={t.label}>
              <div class="tmx-tier-emoji" aria-hidden="true">{t.emoji}</div>
              <div class="tmx-tier-body">
                <div class="tmx-tier-headline">
                  <span class="tmx-tier-name">{t.label}</span>
                  <span class="tmx-tier-range">{t.range}</span>
                </div>
                <p class="tmx-tier-quip">{t.quip}</p>
              </div>
            </li>
          ))}
        </ol>
        <p class="tmx-tiers-footnote">
          API users (pay per token, no plan to multiply against) get equivalent absolute thresholds,
          calibrated against Max-5x so the tier name carries the same meaning:
          <span class="tmx-tiers-fallback">{tiers.map(t => `${t.label.replace('Token','')} ${t.apiFallback}`).join(' · ')}</span>.
        </p>
      </section>

      <!-- WHAT NEXT -->
      <section class="tmx-next-section">
        <h2 class="tmx-next-h2">What does it actually do with that?</h2>
        <p>
          The tier is the shock value. The point of the tool is what comes next:
          <code>tj optimize</code> runs five analyzers against your usage history and
          surfaces specific savings candidates: sessions where a cheaper model would
          have done the same job, prompt sections you could trim, prefixes you could
          cache, deterministic sequences you could replace with a script, and repeated
          planning you could serve from a template instead of regenerating.
        </p>
        <div class="tmx-next-ctas">
          <a class="btn-secondary" href="/products/downsize" onclick="window.trackEvent && window.trackEvent('cta_click', 'engagement', 'tokenmaxx_to_downsize')">See how Downsize works →</a>
          <a class="btn-secondary" href="/observe" onclick="window.trackEvent && window.trackEvent('cta_click', 'engagement', 'tokenmaxx_to_observe')">Or the full observability stack →</a>
        </div>
      </section>

    </article>
  </main>

  <style>
    .tmx {
      max-width: 880px;
      margin: 0 auto;
      padding: 24px 24px 96px;
    }

    /* HERO */
    .tmx-hero {
      text-align: center;
      margin-bottom: 56px;
    }
    .tmx-hero-h1 {
      font-family: 'Geist', sans-serif;
      font-size: clamp(34px, 5.5vw, 60px);
      font-weight: 700;
      letter-spacing: -0.025em;
      line-height: 1.05;
      margin: 0 0 18px;
    }
    /* "TokenMaxxing" accent — red to match the 🔥🔥🔥 GigaMaxxer tier highlight
       and signal the cost-of-burning-tokens vibe. Avoids the muted on-brand
       blue, which read as just another section header. */
    .tmx-hero-accent {
      color: #EF4444;
    }
    .tmx-hero-sub {
      font-family: 'Geist', sans-serif;
      font-size: clamp(16px, 1.5vw, 18px);
      line-height: 1.55;
      color: var(--white-faint);
      max-width: 620px;
      margin: 0 auto;
    }

    /* INSTALL */
    .tmx-install-section { margin-bottom: 72px; }
    .tmx-install-card {
      max-width: 640px;
      margin: 0 auto;
    }
    .tmx-install-term { margin-bottom: 16px; }
    .tmx-install-body { padding: 18px 20px; }
    .tmx-install-body .tline { display: block; line-height: 1.9; }
    .tmx-install-body .t-prompt { color: var(--accent-blue); margin-right: 6px; user-select: none; }
    .tmx-install-body .t-cmd { color: var(--white); font-family: 'Geist Mono', monospace; }
    .tmx-install-ctas {
      display: flex;
      gap: 10px;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }
    .tmx-install-trust {
      font-family: 'Geist', sans-serif;
      font-size: 13px;
      color: var(--white-faint);
      text-align: center;
      margin: 0;
    }
    .tmx-install-trust code {
      font-family: 'Geist Mono', monospace;
      font-size: 0.9em;
      padding: 1px 5px;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 4px;
    }

    /* TIERS */
    .tmx-tiers-section { margin-bottom: 80px; }
    .tmx-tiers {
      list-style: none;
      padding: 0;
      margin: 36px 0 0;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .tmx-tier {
      display: flex;
      align-items: center;
      gap: 24px;
      padding: 18px 24px;
      background: var(--navy-2);
      border: 1px solid var(--blue-line);
      border-radius: 12px;
      transition: border-color 160ms ease, background-color 160ms ease;
    }
    .tmx-tier:hover {
      background: rgba(255, 255, 255, 0.035);
      border-color: rgba(255, 255, 255, 0.18);
    }
    /* The TokenGigaMaxxer row (top tier, 50×+) gets a subtle warning glow to
       mirror the 🔥🔥🔥 emphasis. */
    .tmx-tier[data-tier="TokenGigaMaxxer"] {
      background: linear-gradient(90deg, rgba(239, 68, 68, 0.08), rgba(245, 158, 11, 0.04));
      border-color: rgba(239, 68, 68, 0.35);
    }
    .tmx-tier-emoji {
      font-size: 32px;
      line-height: 1;
      flex-shrink: 0;
      width: 56px;
      text-align: center;
    }
    .tmx-tier-body {
      flex: 1;
      min-width: 0;
    }
    .tmx-tier-headline {
      display: flex;
      align-items: baseline;
      gap: 14px;
      margin-bottom: 4px;
      flex-wrap: wrap;
    }
    .tmx-tier-name {
      font-family: 'Geist', sans-serif;
      font-size: 18px;
      font-weight: 600;
      color: var(--white);
    }
    .tmx-tier-range {
      font-family: 'Geist Mono', monospace;
      font-size: 13px;
      color: var(--white-faint);
    }
    .tmx-tier-quip {
      font-family: 'Geist', sans-serif;
      font-size: 14px;
      font-style: italic;
      color: var(--white-faint);
      margin: 0;
    }

    /* WHAT NEXT */
    .tmx-next-section {
      max-width: 720px;
      margin: 0 auto 80px;
      text-align: center;
    }
    .tmx-next-h2 {
      font-family: 'Geist', sans-serif;
      font-size: clamp(22px, 2.6vw, 30px);
      font-weight: 600;
      letter-spacing: -0.015em;
      margin: 0 0 18px;
    }
    .tmx-next-section p {
      font-family: 'Geist', sans-serif;
      font-size: 16px;
      line-height: 1.6;
      color: var(--white-faint);
      margin: 0 0 24px;
    }
    .tmx-next-section code {
      font-family: 'Geist Mono', monospace;
      font-size: 0.92em;
      padding: 2px 6px;
      background: rgba(255, 255, 255, 0.06);
      border-radius: 4px;
      color: var(--white);
    }
    .tmx-next-ctas {
      display: flex;
      gap: 10px;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* SAMPLE OUTPUT — the screenshot preview block. Renders the exact
       Panel output of `tj tokenmaxx` with the same green / teal color
       cues so the page artifact reads as identical to the terminal one. */
    .tmx-sample-section {
      margin: 0 0 28px;
    }
    .tmx-sample-caption {
      font-family: 'Geist', sans-serif;
      font-size: 13px;
      color: var(--white-faint);
      text-align: center;
      margin: 0 0 12px;
    }
    .tmx-sample {
      /* Default sample text uses the theme-aware primary color, so
         prose ("Touch grass", "in last 30d", "for the full report") is
         high-contrast in both light and dark themes. Only the box-
         drawing characters are dimmed via .tmx-sample-border. */
      font-family: 'Geist Mono', monospace;
      font-size: 12.5px;
      line-height: 1.4;
      background: var(--navy-2);
      color: var(--white);
      border: 1px solid var(--blue-line);
      border-radius: 10px;
      padding: 18px 20px;
      overflow-x: auto;
      margin: 0;
      white-space: pre;
    }
    /* Only the box-drawing characters use the dimmed border style. */
    .tmx-sample-border    { color: var(--white-faint); opacity: 0.55; }
    .tmx-sample-title     { color: var(--white); font-weight: 700; }
    /* Bold/numeric emphasis: full primary color + heavier weight so
       numbers ($4056.82, 40.6×, 33) anchor the eye. */
    .tmx-sample-bold      { color: var(--white); font-weight: 700; }
    /* Brand accents — absolute hex so they work in both themes. */
    .tmx-sample-green     { color: #16A34A; font-weight: 700; }
    .tmx-sample-teal      { color: #0891B2; }
    .tmx-sample-teal-bold { color: #0891B2; font-weight: 700; }

    /* SHARE-ON-X strip — bright, pinned right under the sample so the
       CTA sits where the eye lands after reading the preview. Uses X
       brand color (near-black with high-contrast border) to read as
       platform-specific without competing with the rest of the page. */
    .tmx-share-strip {
      margin: 0 0 80px;
      padding: 22px 24px;
      background: linear-gradient(
        135deg,
        rgba(34, 211, 238, 0.10) 0%,
        rgba(34, 211, 238, 0.04) 100%
      );
      border: 1px solid rgba(34, 211, 238, 0.35);
      border-radius: 16px;
    }
    .tmx-share-inner {
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }
    .tmx-share-icon {
      flex-shrink: 0;
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 10px;
      background: rgba(255, 255, 255, 0.06);
      color: var(--white);
    }
    .tmx-share-icon svg { width: 20px; height: 20px; }
    .tmx-share-body {
      flex: 1;
      min-width: 200px;
    }
    .tmx-share-body h2 {
      font-family: 'Geist', sans-serif;
      font-size: clamp(18px, 2vw, 22px);
      font-weight: 600;
      letter-spacing: -0.01em;
      margin: 0 0 4px;
      color: var(--white);
    }
    .tmx-share-body p {
      font-family: 'Geist', sans-serif;
      font-size: 14px;
      color: var(--white-faint);
      margin: 0;
    }
    .tmx-share-body strong {
      color: var(--white);
    }
    /* X "Share" button — canonical X brand look: solid black background,
       white text + logo, with a subtle white border for definition. Uses
       absolute hex (not theme tokens) so it stays branded in both light
       and dark themes. */
    .tmx-share-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      background: #000;
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 8px;
      font-family: 'Geist', sans-serif;
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      transition: transform 120ms ease, background-color 120ms ease;
      flex-shrink: 0;
    }
    .tmx-share-btn:hover {
      background: #1a1a1a;
      transform: translateY(-1px);
    }
    .tmx-share-btn svg { color: #fff; }

    /* Tier-ladder footnote — single line of API-fallback thresholds at
       the bottom of the tier list so the visual stays multiplier-first
       but API users still see their equivalent absolute thresholds. */
    .tmx-tiers-footnote {
      font-family: 'Geist', sans-serif;
      font-size: 12.5px;
      line-height: 1.55;
      color: var(--white-faint);
      margin: 18px 4px 0;
      text-align: center;
    }
    .tmx-tiers-fallback {
      display: block;
      margin-top: 4px;
      font-family: 'Geist Mono', monospace;
      font-size: 11.5px;
      color: var(--white);
      opacity: 0.85;
    }

    @media (max-width: 600px) {
      .tmx { padding: 40px 16px 64px; }
      .tmx-tier { padding: 14px 16px; gap: 14px; }
      .tmx-tier-emoji { font-size: 26px; width: 40px; }
      .tmx-sample { font-size: 10px; padding: 14px; }
      .tmx-share-btn { width: 100%; justify-content: center; }
    }
  </style>

  <script is:inline>
    (function () {
      var btn = document.getElementById('tmx-copy-btn');
      var label = document.getElementById('tmx-copy-label');
      if (!btn || !label) return;
      btn.addEventListener('click', function () {
        var cmd = btn.dataset.cmd || '';
        if (!cmd) return;
        navigator.clipboard.writeText(cmd).then(function () {
          var prev = label.textContent;
          label.textContent = 'Copied ✓';
          setTimeout(function () { label.textContent = prev; }, 1500);
        });
      });
    })();
  </script>
</BaseLayout>
