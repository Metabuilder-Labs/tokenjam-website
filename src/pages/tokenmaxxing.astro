---
import BaseLayout from '@/layouts/BaseLayout.astro';

// The 5 tiers — copy stays in sync with tokenjam/cli/cmd_tokenmaxx.py.
// If the CLI thresholds or quips change, update both.
const tiers = [
  { emoji: '💧',   label: 'TokenSipper',    range: '< $50/mo',           quip: 'Are you even using AI?' },
  { emoji: '🥱',   label: 'TokenModerator', range: '$50 – $200/mo',      quip: 'Mostly reasonable. Try harder.' },
  { emoji: '💸',   label: 'TokenMaxxer',    range: '$200 – $500/mo',     quip: 'You\'re paying Anthropic\'s rent.' },
  { emoji: '🔥',   label: 'TokenChad',      range: '$500 – $1,500/mo',   quip: 'You\'re paying their interns\' rent too.' },
  { emoji: '🔥🔥', label: 'TokenGigaChad', range: '$1,500+/mo',          quip: 'Touch grass. Then run `tj optimize`.' },
];

// Three commands the tweet promises. Keep these verbatim with the social copy.
const installLines = [
  'pip install tokenjam',
  'tj onboard --claude-code',
  'tj tokenmaxx',
];
const installJoined = installLines.join('\n');
---
<BaseLayout
  title="How hard are you TokenMaxxing? — TokenJam"
  description="Find out your AI token-spending tier in three commands. TokenJam reads your existing Claude Code session logs and classifies your 30-day usage into a tier from TokenSipper to TokenGigaChad. Open-source, local-first, no signup."
  image="/og-image.png"
>
  <main class="tj-main">
    <article class="tmx">

      <!-- HERO -->
      <header class="tmx-hero">
        <p class="tmx-hero-eyebrow">tokenmaxx</p>
        <h1 class="tmx-hero-h1">How hard are you TokenMaxxing?</h1>
        <p class="tmx-hero-sub">
          Everyone's pushing agent loops, deeper chains, bigger context windows.
          Nobody's telling you what they cost. Find out your tier in
          <strong>3 commands</strong> — no signup, runs entirely on your machine.
        </p>
      </header>

      <!-- INSTALL — top of page so people who came to install see it before the meme -->
      <section class="tmx-install-section">
        <div class="tmx-install-card">
          <div class="terminal tmx-install-term">
            <div class="terminal-titlebar">
              <span class="dot dot-r"></span>
              <span class="dot dot-y"></span>
              <span class="dot dot-g"></span>
              <span class="terminal-title">find out your tier</span>
            </div>
            <div class="terminal-body tmx-install-body">
              {installLines.map((cmd) => (
                <span class="tline"><span class="t-prompt">$ </span><span class="t-cmd">{cmd}</span></span>
              ))}
            </div>
          </div>
          <div class="tmx-install-ctas">
            <button class="btn-primary" id="tmx-copy-btn" data-cmd={installJoined} type="button" onclick="window.trackEvent && window.trackEvent('cta_click', 'conversion', 'tokenmaxx_copy_install')">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="4" y="4" width="8" height="8" rx="1.5"/><path d="M2 10V3a1 1 0 011-1h7"/></svg>
              <span id="tmx-copy-label">Copy 3 commands</span>
            </button>
            <a class="btn-secondary" href="https://github.com/metabuilder-labs/tokenjam" target="_blank" rel="noopener noreferrer" onclick="window.trackEvent && window.trackEvent('cta_click', 'conversion', 'tokenmaxx_view_github')">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
              View on GitHub
            </a>
          </div>
          <p class="tmx-install-trust">
            Reads your existing <code>~/.claude/projects/</code> logs · 30 days of history · MIT-licensed
          </p>
        </div>
      </section>

      <!-- TIER LADDER -->
      <section class="tmx-tiers-section">
        <header class="section-head">
          <h2 class="section-h2">The 5 tiers</h2>
          <p class="section-lede">
            Classification is based on your monthly Claude Code spend over the last 30 days.
            Plan-aware: if you're on Max-5x or Max-20x, the output also shows the multiplier vs your flat fee.
          </p>
        </header>
        <ol class="tmx-tiers">
          {tiers.map((t) => (
            <li class="tmx-tier" data-tier={t.label}>
              <div class="tmx-tier-emoji" aria-hidden="true">{t.emoji}</div>
              <div class="tmx-tier-body">
                <div class="tmx-tier-headline">
                  <span class="tmx-tier-name">{t.label}</span>
                  <span class="tmx-tier-range">{t.range}</span>
                </div>
                <p class="tmx-tier-quip">{t.quip}</p>
              </div>
            </li>
          ))}
        </ol>
      </section>

      <!-- WHAT NEXT -->
      <section class="tmx-next-section">
        <h2 class="tmx-next-h2">What does it actually do with that?</h2>
        <p>
          The tier is the shock value. The point of the tool is what comes next:
          <code>tj optimize</code> runs four analyzers against your usage history and
          surfaces specific savings candidates — sessions where a cheaper model would
          have done the same job, prompt sections you could trim, prefixes you could
          cache, deterministic sequences you could replace with a script.
        </p>
        <div class="tmx-next-ctas">
          <a class="btn-secondary" href="/products/downsize" onclick="window.trackEvent && window.trackEvent('cta_click', 'engagement', 'tokenmaxx_to_downsize')">See how Downsize works →</a>
          <a class="btn-secondary" href="/observe" onclick="window.trackEvent && window.trackEvent('cta_click', 'engagement', 'tokenmaxx_to_observe')">Or the full observability stack →</a>
        </div>
      </section>

      <!-- SHARE -->
      <section class="tmx-share-section">
        <h2 class="tmx-share-h2">Post your tier.</h2>
        <p>
          Run <code>tj tokenmaxx</code>, screenshot the output, and post with
          <strong>#tokenmaxx</strong>. We'll boost the best ones.
        </p>
      </section>

    </article>
  </main>

  <style>
    .tmx {
      max-width: 880px;
      margin: 0 auto;
      padding: 60px 24px 96px;
    }

    /* HERO */
    .tmx-hero {
      text-align: center;
      margin-bottom: 56px;
    }
    .tmx-hero-eyebrow {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 999px;
      background: rgba(var(--accent-blue-rgb), 0.12);
      color: var(--accent-blue);
      font-family: 'Geist Mono', monospace;
      font-size: 11px;
      letter-spacing: .1em;
      text-transform: uppercase;
      margin: 0 0 18px;
    }
    .tmx-hero-h1 {
      font-family: 'Geist', sans-serif;
      font-size: clamp(34px, 5.5vw, 60px);
      font-weight: 700;
      letter-spacing: -0.025em;
      line-height: 1.05;
      margin: 0 0 18px;
    }
    .tmx-hero-sub {
      font-family: 'Geist', sans-serif;
      font-size: clamp(16px, 1.5vw, 18px);
      line-height: 1.55;
      color: var(--white-faint);
      max-width: 620px;
      margin: 0 auto;
    }

    /* INSTALL */
    .tmx-install-section { margin-bottom: 72px; }
    .tmx-install-card {
      max-width: 640px;
      margin: 0 auto;
    }
    .tmx-install-term { margin-bottom: 16px; }
    .tmx-install-body { padding: 18px 20px; }
    .tmx-install-body .tline { display: block; line-height: 1.9; }
    .tmx-install-body .t-prompt { color: var(--accent-blue); margin-right: 6px; user-select: none; }
    .tmx-install-body .t-cmd { color: var(--white); font-family: 'Geist Mono', monospace; }
    .tmx-install-ctas {
      display: flex;
      gap: 10px;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }
    .tmx-install-trust {
      font-family: 'Geist', sans-serif;
      font-size: 13px;
      color: var(--white-faint);
      text-align: center;
      margin: 0;
    }
    .tmx-install-trust code {
      font-family: 'Geist Mono', monospace;
      font-size: 0.9em;
      padding: 1px 5px;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 4px;
    }

    /* TIERS */
    .tmx-tiers-section { margin-bottom: 80px; }
    .tmx-tiers {
      list-style: none;
      padding: 0;
      margin: 36px 0 0;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .tmx-tier {
      display: flex;
      align-items: center;
      gap: 24px;
      padding: 18px 24px;
      background: var(--navy-2);
      border: 1px solid var(--blue-line);
      border-radius: 12px;
      transition: border-color 160ms ease, background-color 160ms ease;
    }
    .tmx-tier:hover {
      background: rgba(255, 255, 255, 0.035);
      border-color: rgba(255, 255, 255, 0.18);
    }
    /* The TokenGigaChad row gets a subtle warning glow to mirror the 🔥🔥 emphasis */
    .tmx-tier[data-tier="TokenGigaChad"] {
      background: linear-gradient(90deg, rgba(239, 68, 68, 0.08), rgba(245, 158, 11, 0.04));
      border-color: rgba(239, 68, 68, 0.35);
    }
    .tmx-tier-emoji {
      font-size: 32px;
      line-height: 1;
      flex-shrink: 0;
      width: 56px;
      text-align: center;
    }
    .tmx-tier-body {
      flex: 1;
      min-width: 0;
    }
    .tmx-tier-headline {
      display: flex;
      align-items: baseline;
      gap: 14px;
      margin-bottom: 4px;
      flex-wrap: wrap;
    }
    .tmx-tier-name {
      font-family: 'Geist', sans-serif;
      font-size: 18px;
      font-weight: 600;
      color: var(--white);
    }
    .tmx-tier-range {
      font-family: 'Geist Mono', monospace;
      font-size: 13px;
      color: var(--white-faint);
    }
    .tmx-tier-quip {
      font-family: 'Geist', sans-serif;
      font-size: 14px;
      font-style: italic;
      color: var(--white-faint);
      margin: 0;
    }

    /* WHAT NEXT */
    .tmx-next-section {
      max-width: 720px;
      margin: 0 auto 80px;
      text-align: center;
    }
    .tmx-next-h2 {
      font-family: 'Geist', sans-serif;
      font-size: clamp(22px, 2.6vw, 30px);
      font-weight: 600;
      letter-spacing: -0.015em;
      margin: 0 0 18px;
    }
    .tmx-next-section p {
      font-family: 'Geist', sans-serif;
      font-size: 16px;
      line-height: 1.6;
      color: var(--white-faint);
      margin: 0 0 24px;
    }
    .tmx-next-section code {
      font-family: 'Geist Mono', monospace;
      font-size: 0.92em;
      padding: 2px 6px;
      background: rgba(255, 255, 255, 0.06);
      border-radius: 4px;
      color: var(--white);
    }
    .tmx-next-ctas {
      display: flex;
      gap: 10px;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* SHARE */
    .tmx-share-section {
      text-align: center;
      padding: 40px 28px;
      background: rgba(var(--accent-blue-rgb), 0.05);
      border: 1px solid rgba(var(--accent-blue-rgb), 0.20);
      border-radius: 16px;
    }
    .tmx-share-h2 {
      font-family: 'Geist', sans-serif;
      font-size: clamp(20px, 2.4vw, 26px);
      font-weight: 600;
      letter-spacing: -0.01em;
      margin: 0 0 12px;
    }
    .tmx-share-section p {
      font-family: 'Geist', sans-serif;
      font-size: 15px;
      line-height: 1.55;
      color: var(--white-faint);
      margin: 0;
    }
    .tmx-share-section code {
      font-family: 'Geist Mono', monospace;
      font-size: 0.92em;
      padding: 2px 6px;
      background: rgba(255, 255, 255, 0.08);
      border-radius: 4px;
      color: var(--white);
    }

    @media (max-width: 600px) {
      .tmx { padding: 40px 16px 64px; }
      .tmx-tier { padding: 14px 16px; gap: 14px; }
      .tmx-tier-emoji { font-size: 26px; width: 40px; }
    }
  </style>

  <script is:inline>
    (function () {
      var btn = document.getElementById('tmx-copy-btn');
      var label = document.getElementById('tmx-copy-label');
      if (!btn || !label) return;
      btn.addEventListener('click', function () {
        var cmd = btn.dataset.cmd || '';
        if (!cmd) return;
        navigator.clipboard.writeText(cmd).then(function () {
          var prev = label.textContent;
          label.textContent = 'Copied ✓';
          setTimeout(function () { label.textContent = prev; }, 1500);
        });
      });
    })();
  </script>
</BaseLayout>
