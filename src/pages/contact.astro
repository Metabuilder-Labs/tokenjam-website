---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact — TokenJam"
  description="Get in touch with the TokenJam team. Drop us a line at hello@metabldr.com."
>
  <main class="tj-main">
    <div class="contact">
      <h1>Get in touch</h1>
      <p class="contact-line">
        Drop us a line at <a href="mailto:hello@metabldr.com">hello@metabldr.com</a>.
      </p>
    </div>
  </main>

  <style>
    .contact {
      max-width: 640px;
      margin: 0 auto;
      padding: 40px 0;
      text-align: center;
    }
    .contact h1 {
      font-family: 'Geist', sans-serif;
      font-size: clamp(36px, 4.4vw, 52px);
      font-weight: 700;
      letter-spacing: -.025em;
      line-height: 1.1;
      color: var(--white);
      margin: 0 0 20px;
    }
    .contact-line {
      color: var(--white-dim);
      font-size: 19px;
      line-height: 1.55;
      margin: 0;
    }
    .contact-line a {
      color: var(--accent-blue);
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .contact-line a:hover { color: var(--white); }
  </style>
</BaseLayout>
