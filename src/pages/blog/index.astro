---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublishedPosts, readingTimeMinutes } from '@/lib/blog';
import Schema from '@/components/Schema.astro';
import { organizationSchema } from '@/lib/schema';

const posts = await getPublishedPosts();
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

// Curated top-level filter groups. Each group maps a display label to a set of
// underlying post tags. Keeps the filter row from ballooning as the long-tail
// tag set grows. Only groups that actually match at least one post are rendered.
const tagGroups: { label: string; tags: string[] }[] = [
  { label: 'Agents',        tags: ['agents', 'claude-code', 'cursor', 'agent-failure'] },
  { label: 'Cost',          tags: ['cost', 'tokens', 'pricing', 'optimization'] },
  { label: 'Observability', tags: ['observability', 'telemetry', 'opentelemetry', 'monitoring', 'drift', 'alerts'] },
  { label: 'Evaluation',    tags: ['evaluation', 'testing', 'benchmarks'] },
  { label: 'Retrieval',     tags: ['retrieval'] },
  { label: 'Gateways',      tags: ['gateways', 'infrastructure', 'control-plane'] },
  { label: 'Governance',    tags: ['governance', 'guardrails', 'safety', 'hitl', 'approval'] },
  { label: 'Memory',        tags: ['memory'] },
  { label: 'Thesis',        tags: ['thesis', 'industry'] },
];
const usedTags = new Set<string>();
for (const p of posts) for (const t of p.data.tags ?? []) usedTags.add(t);
const visibleGroups = tagGroups.filter((g) => g.tags.some((t) => usedTags.has(t)));

const featured = posts[0];
const rest = posts.slice(1);
---
<BaseLayout
  title="Blog — TokenJam"
  description="Notes from TokenJam on token economics for AI agents: cost optimization, observability, evaluation, behavioral control, and the agentic ecosystem around them."
  wide
>
  <div class="blog-wrap">
    <header class="blog-hero">
      <h1>Blog</h1>
    </header>

    {visibleGroups.length > 0 && (
      <div class="blog-filter" role="tablist" aria-label="Filter posts by topic">
        <button type="button" class="blog-filter-pill is-active" data-tags="" role="tab" aria-selected="true">All</button>
        {visibleGroups.map((g) => (
          <button
            type="button"
            class="blog-filter-pill"
            data-tags={g.tags.join(',')}
            role="tab"
            aria-selected="false"
          >{g.label}</button>
        ))}
      </div>
    )}

    {posts.length === 0 ? (
      <p style="color: var(--white-dim);">No posts yet. Check back soon.</p>
    ) : (
      <>
        {featured && (
          <a
            href={`/blog/${featured.id}`}
            class="blog-featured"
            data-tags={(featured.data.tags ?? []).join(',')}
          >
            {featured.data.image && (
              <div class="blog-featured-media">
                <img src={featured.data.image} alt={featured.data.title} loading="eager" />
              </div>
            )}
            <div class="blog-featured-body">
              {featured.data.tags?.length > 0 && (
                <div class="blog-card-tags">
                  {featured.data.tags.map((t) => <span class="blog-card-tag">{t}</span>)}
                </div>
              )}
              <h2 class="blog-featured-title">{featured.data.title}</h2>
              <p class="blog-featured-desc">{featured.data.description}</p>
              <div class="blog-card-meta">
                <time datetime={featured.data.publishDate.toISOString()}>{fmt(featured.data.publishDate)}</time>
                <span>·</span>
                <span>{readingTimeMinutes(featured.body)} min read</span>
              </div>
            </div>
          </a>
        )}

        {rest.length > 0 && (
          <ul class="blog-grid">
            {rest.map((post) => (
              <li data-tags={(post.data.tags ?? []).join(',')}>
                <a href={`/blog/${post.id}`} class="blog-card">
                  {post.data.image && (
                    <div class="blog-card-media">
                      <img src={post.data.image} alt={post.data.title} loading="lazy" />
                    </div>
                  )}
                  <div class="blog-card-body">
                    {post.data.tags?.length > 0 && (
                      <div class="blog-card-tags">
                        {post.data.tags.map((t) => <span class="blog-card-tag">{t}</span>)}
                      </div>
                    )}
                    <h3 class="blog-card-title">{post.data.title}</h3>
                    <p class="blog-card-desc">{post.data.description}</p>
                    <div class="blog-card-meta">
                      <time datetime={post.data.publishDate.toISOString()}>{fmt(post.data.publishDate)}</time>
                      <span>·</span>
                      <span>{readingTimeMinutes(post.body)} min read</span>
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )}
      </>
    )}
  </div>

  <Schema data={organizationSchema()} />

  <script is:inline>
    (function () {
      var pills = document.querySelectorAll('.blog-filter-pill');
      if (!pills.length) return;
      var items = Array.prototype.slice.call(document.querySelectorAll('[data-tags]'));
      pills.forEach(function (pill) {
        pill.addEventListener('click', function () {
          var groupTags = (pill.dataset.tags || '').split(',').filter(Boolean);
          pills.forEach(function (p) {
            var active = p === pill;
            p.classList.toggle('is-active', active);
            p.setAttribute('aria-selected', active ? 'true' : 'false');
          });
          items.forEach(function (item) {
            if (groupTags.length === 0) { item.style.display = ''; return; }
            var postTags = (item.dataset.tags || '').split(',');
            var match = groupTags.some(function (gt) { return postTags.indexOf(gt) !== -1; });
            item.style.display = match ? '' : 'none';
          });
        });
      });
    })();
  </script>
</BaseLayout>
