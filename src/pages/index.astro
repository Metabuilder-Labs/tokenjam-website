  <style is:global>
    /* ── Beam SVG (global so JS-created paths/circles match) ── */
    .flow-svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 1;
      overflow: visible;
    }
    .flow-beam {
      fill: none;
      stroke: currentColor;
      stroke-width: 1;
      opacity: 0.16;
      color: var(--white);
      transition: opacity .25s, stroke-width .25s;
    }
    .flow-beam.is-active {
      opacity: 0.55;
      stroke-width: 1.4;
      color: var(--accent-blue);
    }
    .flow-particle {
      fill: var(--accent-blue);
      filter: drop-shadow(0 0 4px rgba(var(--accent-blue-rgb), 0.9));
    }
  </style>

  <style>
    /* Generic section header */
    .section-head {
      max-width: 1100px;
      margin: 0 auto 36px;
      padding: 0 40px;
      text-align: center;
    }
    .section-h2 {
      font-family: 'Geist', sans-serif;
      font-weight: 600;
      letter-spacing: -.02em;
      font-size: clamp(28px, 3.4vw, 40px);
      color: var(--white);
      margin: 0 0 10px;
    }
    .section-lede {
      color: var(--white-dim);
      font-size: 17px;
      max-width: 900px;
      margin: 0 auto;
    }

    /* Buttons (extend nav .btn-primary) */
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: 'Geist', sans-serif;
      font-size: 13px;
      font-weight: 500;
      color: var(--white);
      background: transparent;
      padding: 7px 16px;
      border: 1px solid rgba(var(--accent-rgb), 0.2);
      border-radius: 6px;
      text-decoration: none;
      cursor: pointer;
      transition: border-color .15s, background .15s;
    }
    .btn-secondary:hover { border-color: rgba(var(--accent-rgb), 0.4); background: var(--white-ghost); }
    .btn-lg { padding: 11px 22px; font-size: 14px; border-radius: 8px; }

    /* ── HERO ─────────────────────────────────────── */
    .hero {
      padding: calc(120px + var(--banner-h, 0px)) 48px 80px;
      background:
        radial-gradient(ellipse 80% 50% at 50% 0%, rgba(var(--accent-blue-rgb), 0.08), transparent 60%),
        var(--navy);
      border-bottom: 1px solid var(--blue-line);
    }
    .hero-inner {
      max-width: 1440px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 48px;
    }
    .hero-copy { text-align: center; max-width: none; margin: 0 auto; }
    /* Single-line headline (Vercel-style hero). The calc() picks the largest font
       that fits the ~38-char string in (viewport - 96px); clamp() floors small
       screens and caps very wide ones. JS below mirrors the rendered width onto
       --hero-h1-width so .hero-sub stays within the same L/R bounds. */
    .hero-h1 {
      font-family: 'Geist', sans-serif;
      font-weight: 600;
      letter-spacing: -.03em;
      line-height: 1.08;
      font-size: clamp(34px, calc((100vw - 96px) / 19), 84px);
      color: var(--white);
      margin: 0 0 24px;
      white-space: nowrap;
    }
    @media (max-width: 720px) {
      .hero-h1 { white-space: normal; }
    }
    /* Subhead is ~175 chars — won't fit on one line until ~1700px viewport, but at that point
       we let it stretch. Below that it wraps cleanly inside a generous max-width. */
    /* max-width is synced to the rendered .hero-h1 width by JS below, so the subhead
       always lives within the headline's L/R bounds regardless of viewport size. */
    .hero-sub {
      color: var(--white-dim);
      font-size: clamp(16px, 1.3vw, 19px);
      line-height: 1.55;
      max-width: var(--hero-h1-width, 100%);
      margin: 0 auto;
      white-space: normal;
    }
    .hero-sub-faint { color: var(--white-faint); }
    p.hero-sub + p.hero-sub { margin-top: 6px; }
    .hero-ctas {
      display: flex;
      gap: 12px;
      justify-content: center;
      margin-top: 28px;
      flex-wrap: wrap;
    }

    /* ── ANIMATED FLOW ────────────────────────────── */
    .flow-wrap {
      position: relative;
      width: 100%;
      max-width: 1320px;
      margin: 0 auto;
      padding: 8px 20px 0;
    }
    .flow-grid {
      position: relative;
      display: grid;
      grid-template-columns: minmax(200px, 260px) 1fr minmax(240px, 300px);
      gap: clamp(60px, 8vw, 140px);
      align-items: center;
      min-height: 500px;
    }
    .flow-sources, .flow-products {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
      position: relative;
      z-index: 2;
    }
    .flow-node {
      position: relative;
      background: var(--navy-2);
      border: 1px solid var(--blue-line);
      border-radius: 8px;
      transition: border-color .2s, background .2s, transform .2s;
    }
    .flow-source {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 12px;
      font-family: 'Geist Mono', monospace;
      font-size: 12px;
      color: var(--white-dim);
    }
    .flow-source:hover {
      border-color: rgba(var(--brand-rgb), 0.55);
      background: rgba(var(--brand-rgb), 0.06);
      color: var(--white);
    }
    .flow-source-mark {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px; height: 28px;
      border-radius: 6px;
      background: var(--navy-3);
      border: 1px solid rgba(var(--brand-rgb), 0.4);
      color: var(--brand);
    }
    .flow-source-mark.is-multicolor { background: rgba(255, 255, 255, 0.04); }
    .flow-source-mark svg { display: block; }
    .flow-source-name { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    /* Tooltip showing the underlying products for a vendor. Positioned to the right
       of the chip (over the diagram beam area). Hidden on small screens. */
    .flow-source-tooltip {
      position: absolute;
      top: 50%;
      left: calc(100% + 12px);
      transform: translateY(-50%);
      background: var(--navy);
      border: 1px solid rgba(var(--brand-rgb), 0.4);
      border-radius: 8px;
      padding: 10px 14px;
      font-family: 'Geist Mono', monospace;
      font-size: 11px;
      line-height: 1.55;
      color: var(--white-dim);
      white-space: nowrap;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.45);
      opacity: 0;
      pointer-events: none;
      transition: opacity .18s;
      z-index: 5;
    }
    .flow-source:hover .flow-source-tooltip,
    .flow-source:focus-within .flow-source-tooltip {
      opacity: 1;
    }
    .flow-source-tooltip-row {
      display: flex; align-items: center; gap: 8px;
    }
    .flow-source-tooltip-dot {
      width: 4px; height: 4px;
      border-radius: 50%;
      background: var(--brand);
      flex-shrink: 0;
    }
    @media (max-width: 820px) {
      .flow-source-tooltip { display: none; }
    }

    .flow-center {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 3;
      min-height: 240px;
    }
    .flow-center-ring {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 180px; height: 180px;
      border-radius: 50%;
      border: 1px solid var(--blue-line);
      background: var(--navy);
      box-shadow: 0 0 0 6px var(--white-ghost);
      pointer-events: none;
    }
    .flow-center-label {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      z-index: 1;
    }
    .flow-center-mark {
      width: 64px;
      height: auto;
      color: var(--white);
    }
    .flow-center-name {
      font-family: 'Geist Mono', monospace;
      font-size: 11px;
      letter-spacing: .14em;
      color: var(--white-dim);
    }

    .flow-product {
      padding: 0;
    }
    .flow-product-link {
      display: flex; align-items: center; gap: 10px;
      padding: 12px 14px;
      text-decoration: none;
      color: var(--white);
      border-radius: 7px;
    }
    /* Per-analyzer icon coloured by the product's accent var. Observe overrides
       to neutral white via its inline --product-accent. */
    .flow-product-icon {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 18px; height: 18px;
      color: var(--product-accent, var(--white-faint));
      filter: drop-shadow(0 0 4px rgba(var(--product-accent-rgb, 255, 255, 255), 0.45));
    }
    .flow-product-icon svg { width: 14px; height: 14px; }
    .flow-product--observe .flow-product-icon {
      color: var(--white-faint);
      filter: none;
    }
    .flow-product--observe:hover .flow-product-icon { color: var(--white); }
    .flow-product-name {
      font-family: 'Geist', sans-serif;
      font-size: 14px;
      font-weight: 500;
      flex: 1;
    }
    .flow-product-arrow {
      color: var(--white-faint);
      font-size: 14px;
      transition: color .2s, transform .2s;
    }
    .flow-product:hover {
      border-color: rgba(var(--product-accent-rgb, 255, 255, 255), 0.55);
      background: rgba(var(--product-accent-rgb, 255, 255, 255), 0.06);
      transform: translateX(2px);
    }
    .flow-product:hover .flow-product-arrow {
      color: var(--product-accent, var(--accent-blue));
      transform: translateX(2px);
    }

    .flow-svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 1;
    }
    .flow-beam {
      fill: none;
      stroke: rgba(var(--accent-rgb), 0.14);
      stroke-width: 1;
      transition: stroke .25s, stroke-width .25s;
    }
    .flow-beam.is-active {
      stroke: url(#beam-gradient);
      stroke-width: 1.5;
    }
    .flow-particle {
      fill: url(#particle-glow);
    }

    .flow-channels {
      display: flex;
      align-items: center;
      gap: 10px;
      justify-content: center;
      margin-top: 24px;
      font-family: 'Geist Mono', monospace;
      font-size: 12px;
      color: var(--white-dim);
    }
    .flow-channels-label { color: var(--white-faint); }
    .flow-channel {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 4px 10px;
      background: var(--navy-2);
      border: 1px solid var(--blue-line);
      border-radius: 999px;
      color: var(--white-dim);
    }
    .flow-channel svg { color: var(--accent-blue); }
    .flow-dot { color: var(--white-faint); }

    /* Mobile-only flow direction cues — hidden on desktop so the 3-col grid layout is unchanged. */
    .flow-mobile-label, .flow-mobile-rail { display: none; }

    /* Mobile flow: collapse to vertical */
    @media (max-width: 820px) {
      .flow-grid {
        grid-template-columns: 1fr;
        gap: 12px;
        min-height: 0;
      }
      .flow-sources, .flow-products { gap: 8px; }
      .flow-center { min-height: 120px; }
      .flow-svg { display: none; } /* On mobile, just show stacks; beams hide */

      .flow-mobile-label {
        display: block;
        margin: 6px 0 2px;
        text-align: center;
        font-family: 'Geist Mono', monospace;
        font-size: 11px;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--white-faint);
      }
      .flow-mobile-rail {
        display: block;
        position: relative;
        width: 2px;
        height: 56px;
        margin: 4px auto;
        background: linear-gradient(to bottom, transparent, var(--blue-line) 20%, var(--blue-line) 80%, transparent);
        overflow: hidden;
      }
      .flow-mobile-rail span {
        position: absolute;
        left: 50%;
        margin-left: -3px;
        width: 6px; height: 6px;
        border-radius: 50%;
        background: var(--accent-blue);
        box-shadow: 0 0 8px rgba(var(--accent-blue-rgb), 0.85);
        animation: flow-mobile-drop 1.6s linear infinite;
      }
      .flow-mobile-rail span:nth-child(2) { animation-delay: -0.8s; }
      .flow-mobile-rail--out span {
        background: var(--green);
        box-shadow: 0 0 8px rgba(var(--green-rgb), 0.85);
      }
    }
    @keyframes flow-mobile-drop {
      0%   { top: -8px;  opacity: 0; }
      15%  { opacity: 1; }
      85%  { opacity: 1; }
      100% { top: 56px;  opacity: 0; }
    }
    @media (prefers-reduced-motion: reduce) {
      .flow-mobile-rail span { animation: none; top: 24px; }
    }

    @media (prefers-reduced-motion: reduce) {
      .flow-center-glow { animation: none; }
      .flow-particle { display: none; }
    }

    /* ── WORKS-WITH STRIP ─────────────────────────── */
    .works-with {
      padding: 56px 0 64px;
      border-bottom: 1px solid var(--blue-line);
      overflow: hidden;
    }
    .works-with-caption {
      max-width: 720px;
      margin: 0 auto 24px;
      padding: 0 40px;
      text-align: center;
      color: var(--white-dim);
      font-size: 15px;
    }
    .works-with-track {
      width: 100%;
      mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
      -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    }
    .works-with-row {
      display: flex;
      gap: 14px;
      width: max-content;
      animation: works-marquee 60s linear infinite;
    }
    .works-with-pill {
      flex-shrink: 0;
      padding: 8px 16px;
      border: 1px solid var(--blue-line);
      border-radius: 999px;
      background: var(--navy-2);
      font-family: 'Geist Mono', monospace;
      font-size: 12px;
      color: var(--white-dim);
      white-space: nowrap;
    }
    @keyframes works-marquee {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    @media (prefers-reduced-motion: reduce) {
      .works-with-row { animation: none; flex-wrap: wrap; justify-content: center; width: auto; padding: 0 40px; }
    }

    /* ── PRODUCTS GRID ────────────────────────────── */
    .products-grid-section {
      padding: 96px 48px 80px;
      max-width: 1440px;
      margin: 0 auto;
    }
    .products-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 1fr;
      gap: 28px;
      margin-top: 8px;
    }
    /* When the last card sits alone on its row (odd total), span both
       columns and center it at single-card width so it doesn't leave
       an awkward blank slot on the right. */
    .products-grid > article:last-child:nth-child(odd) {
      grid-column: 1 / -1;
      justify-self: center;
      width: 100%;
      max-width: calc(50% - 14px); /* 28px gap / 2 = 14px to match column width */
    }
    .product-card {
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 16px;
      padding: 28px;
      background: var(--navy-2);
      border: 1px solid var(--blue-line);
      border-top: 2px solid var(--product-accent, var(--blue-line));
      border-radius: 14px;
      transition: border-color .2s, transform .2s, box-shadow .2s;
      cursor: pointer;
    }
    /* Full-card click target. Real <a> so it gets browser navigation + pointer cursor +
       keyboard focus by default. aria-label provides accessible naming. Sits on top of
       all non-positioned card content so clicks anywhere hit the overlay first. */
    .product-card-overlay {
      position: absolute;
      inset: 0;
      z-index: 1;
      border-radius: inherit;
    }
    .product-card-overlay:focus-visible {
      outline: 2px solid var(--product-accent, var(--accent-blue));
      outline-offset: 2px;
    }
    .product-card:hover {
      border-color: rgba(var(--product-accent-rgb, 255, 255, 255), 0.35);
      border-top-color: var(--product-accent, var(--white));
      transform: translateY(-2px);
      box-shadow: 0 12px 32px rgba(var(--product-accent-rgb, 0, 0, 0), 0.12);
    }
    .product-card-head { display: flex; flex-direction: column; gap: 6px; }
    .product-card-name {
      display: flex;
      align-items: center;
      gap: 10px;
      font-family: 'Geist', sans-serif;
      font-size: 22px;
      font-weight: 600;
      letter-spacing: -.01em;
      color: var(--product-accent, var(--white));
      margin: 0;
    }
    .product-card-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      border-radius: 7px;
      background: rgba(var(--product-accent-rgb, 255, 255, 255), 0.10);
      color: var(--product-accent, var(--white));
    }
    .product-card-icon svg { width: 16px; height: 16px; }
    .product-card-blurb {
      color: var(--white-dim);
      font-size: 15px;
      line-height: 1.45;
      margin: 0;
    }
    .product-card-term {
      font-size: 12px;
      line-height: 1.6;
      display: flex;
      flex-direction: column;
      flex: 1;
    }
    /* flex:1 + min-height floor — terminal grows to fill available card space, but never
       collapses below the height of the tallest output (Downsize). Shorter outputs trail
       with whitespace at the bottom so all five cards' terminals match visually. */
    .product-card-body {
      padding: 16px 18px;
      margin: 0;
      font-family: 'Geist Mono', monospace;
      overflow: visible;
      white-space: pre-wrap;
      min-height: 320px;
      flex: 1;
    }
    .product-card-link {
      align-self: flex-end;
      font-family: 'Geist Mono', monospace;
      font-size: 13px;
      color: var(--accent-blue);
      text-decoration: none;
      transition: opacity .15s;
    }
    .product-card-link:hover { opacity: .8; }
    .product-card-link span { display: inline-block; transition: transform .15s; }
    .product-card-link:hover span { transform: translateX(3px); }

    .products-cta-strip {
      margin-top: 48px;
      padding: 28px;
      background: var(--navy-2);
      border: 1px solid var(--blue-line);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
      text-align: center;
    }
    .products-cta-strip p {
      margin: 0;
      color: var(--white);
      font-size: 16px;
    }
    .products-cta-buttons { display: flex; gap: 10px; }

    @media (max-width: 820px) {
      .products-grid { grid-template-columns: 1fr; }
      /* On mobile each card already takes the full row, so the
         centering rule for an odd trailing card is unnecessary and
         would visually squash it to half-width. Reset it. */
      .products-grid > article:last-child:nth-child(odd) {
        grid-column: auto;
        justify-self: stretch;
        width: auto;
        max-width: none;
      }
      /* Narrow viewports + mono font make terminals wrap heavily and
         the min-height floor compounds it. Shrink the type and let
         each card hug its own content. Horizontal scroll is the
         escape hatch if a single line is still too wide. */
      .product-card-term { font-size: 11px; line-height: 1.55; }
      .product-card-body {
        font-size: 10.5px;
        min-height: 0;
        padding: 14px 14px;
        white-space: pre;
        overflow-x: auto;
      }
    }

    /* ── HOW IT WORKS ─────────────────────────────── */
    .how {
      padding: 80px 48px;
      max-width: 1280px;
      margin: 0 auto;
      border-top: 1px solid var(--blue-line);
    }
    .how-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .how-col {
      padding: 28px 28px 30px;
      background: var(--navy-2);
      border: 1px solid var(--blue-line);
      border-radius: 14px;
      transition: border-color .2s, transform .2s;
    }
    .how-col:hover { border-color: rgba(var(--accent-rgb), 0.18); transform: translateY(-2px); }
    .how-h3 {
      font-family: 'Geist', sans-serif;
      font-size: 18px;
      font-weight: 600;
      letter-spacing: -.01em;
      color: var(--white);
      margin: 0 0 14px;
    }
    .how-col p {
      color: var(--white-dim);
      font-size: 15px;
      line-height: 1.65;
      margin: 0;
    }
    .how-col code {
      font-family: 'Geist Mono', monospace;
      font-size: .9em;
      padding: 1px 6px;
      background: var(--white-ghost);
      border-radius: 4px;
      color: var(--white);
    }
    @media (max-width: 820px) {
      .how-grid { grid-template-columns: 1fr; gap: 32px; }
    }

    /* ── OBSERVABILITY STRIP ─────────────────────────
       Site-standard neutral treatment: navy-2 surface, hairline border, no
       colored glow. Accent color used only where appropriate (small icon
       chip, link), matching the rest of the site. */
    .observe-strip {
      position: relative;
      margin: 0 auto 80px;
      padding: 64px 48px;
      background: var(--navy-2);
      border: 1px solid var(--blue-line);
      border-radius: 14px;
      max-width: 1440px;
    }
    .observe-head { margin-bottom: 40px; }
    .observe-eyebrow {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 999px;
      background: var(--white-ghost);
      color: var(--white-faint);
      font-family: 'Geist Mono', monospace;
      font-size: 11px;
      letter-spacing: .1em;
      text-transform: uppercase;
      margin: 0 0 14px;
    }
    .observe-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      max-width: 1180px;
      margin: 0 auto;
    }
    .observe-card {
      position: relative;
      padding: 24px 26px;
      background: var(--navy);
      border: 1px solid var(--blue-line);
      border-radius: 12px;
      transition: transform 180ms ease, border-color 180ms ease;
    }
    .observe-card:hover {
      transform: translateY(-2px);
      border-color: rgba(var(--accent-rgb), 0.22);
    }
    .observe-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: var(--white-ghost);
      color: var(--white);
      margin-bottom: 14px;
    }
    /* Per-card icon tones. Colored variants share the analyzer accents
       (matches Trim/Downsize/Cache/Script for visual coherence). The two
       neutral inverts use the theme tokens so they flip correctly between
       light and dark mode. */
    .observe-card[data-tone="green"] .observe-icon { background: rgba(34, 197, 94, 0.14); color: #22C55E; }
    .observe-card[data-tone="blue"]  .observe-icon { background: rgba(59, 130, 246, 0.14); color: #3B82F6; }
    .observe-card[data-tone="red"]   .observe-icon { background: rgba(239, 68, 68, 0.14); color: #EF4444; }
    .observe-card[data-tone="amber"] .observe-icon { background: rgba(245, 158, 11, 0.16); color: #F59E0B; }
    .observe-card[data-tone="invert-light"] .observe-icon { background: var(--white); color: var(--navy); }
    .observe-card[data-tone="invert-dark"]  .observe-icon { background: var(--navy); color: var(--white); border: 1px solid var(--blue-line); }
    .observe-h3 {
      font-family: 'Geist', sans-serif;
      font-size: 16px;
      font-weight: 600;
      letter-spacing: -.01em;
      margin: 0 0 8px;
      color: var(--white);
    }
    .observe-card p {
      font-family: 'Geist', sans-serif;
      font-size: 14px;
      line-height: 1.55;
      color: var(--white-dim);
      margin: 0;
    }
    .observe-card p code {
      font-family: 'Geist Mono', monospace;
      font-size: .9em;
      padding: 1px 5px;
      background: var(--white-ghost);
      border-radius: 4px;
      color: var(--white);
    }
    .observe-strip-cta {
      display: flex;
      justify-content: center;
      margin-top: 36px;
    }
    .observe-cta-link {
      font-family: 'Geist Mono', monospace;
      font-size: 13px;
      color: var(--accent-blue);
      text-decoration: none;
      padding: 8px 16px;
      border: 1px solid rgba(var(--accent-rgb), 0.18);
      border-radius: 999px;
      transition: background-color .15s, border-color .15s;
    }
    .observe-cta-link:hover {
      background: var(--white-ghost);
      border-color: rgba(var(--accent-rgb), 0.35);
    }
    .observe-cta-link span { display: inline-block; transition: transform .15s; }
    .observe-cta-link:hover span { transform: translateX(3px); }
    @media (max-width: 960px) {
      .observe-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 600px) {
      .observe-strip { margin: 0 12px 64px; padding: 44px 22px; }
      .observe-grid { grid-template-columns: 1fr; }
    }

    /* ── CLOUD TEASER ─────────────────────────────── */
    .cloud-teaser {
      margin: 40px 20px 80px;
      padding: 56px 40px;
      background:
        radial-gradient(ellipse 80% 60% at 50% 0%, rgba(var(--accent-blue-rgb), 0.10), transparent 60%),
        var(--navy-2);
      border: 1px solid var(--blue-line);
      border-radius: 16px;
    }
    .cloud-teaser-inner {
      max-width: 760px;
      margin: 0 auto;
      text-align: center;
    }
    .cloud-eyebrow {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 999px;
      background: rgba(var(--accent-blue-rgb), 0.12);
      color: var(--accent-blue);
      font-family: 'Geist Mono', monospace;
      font-size: 11px;
      letter-spacing: .1em;
      text-transform: uppercase;
      margin-bottom: 16px;
    }
    .cloud-h2 {
      font-family: 'Geist', sans-serif;
      font-size: clamp(22px, 2.6vw, 30px);
      font-weight: 600;
      letter-spacing: -.015em;
      line-height: 1.25;
      color: var(--white);
      margin: 0 0 20px;
    }
    .cloud-body {
      color: var(--white-dim);
      font-size: 16px;
      line-height: 1.65;
      margin: 0 0 16px;
    }
    .cloud-body code {
      font-family: 'Geist Mono', monospace;
      font-size: .9em;
      padding: 1px 6px;
      background: var(--white-ghost);
      border-radius: 4px;
      color: var(--white);
    }
    .cloud-teaser .btn-primary { margin-top: 12px; }

    /* ── INSTALL ──────────────────────────────────── */
    .install-section {
      padding: 80px 40px 96px;
      max-width: 720px;
      margin: 0 auto;
    }
    .install-card {
      display: flex;
      flex-direction: column;
      gap: 18px;
      align-items: center;
    }
    .install-term { width: 100%; font-size: 13px; }
    .install-body { padding: 16px 22px; }
    .install-ctas { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }
    #install-copy-btn { gap: 8px; display: inline-flex; align-items: center; }
    .install-trust {
      margin: 0;
      font-family: 'Geist Mono', monospace;
      font-size: 12px;
      color: var(--white-faint);
      text-align: center;
    }

    @media (max-width: 640px) {
      .hero { padding: calc(100px + var(--banner-h, 0px)) 16px 56px; }
      .products-grid-section,
      .how,
      .install-section { padding-left: 16px; padding-right: 16px; }
      .cloud-teaser { padding: 40px 20px; margin: 20px 10px 56px; }
    }

  </style>

  <script is:inline define:vars={{ installJoined }}>
    (function () {
      // ── Sync hero subhead width to the rendered H1 ──
      var heroCopy = document.querySelector('.hero-copy');
      var heroH1 = document.querySelector('.hero-h1');
      function syncHeroSub() {
        if (!heroCopy || !heroH1) return;
        var w = heroH1.getBoundingClientRect().width;
        heroCopy.style.setProperty('--hero-h1-width', w + 'px');
      }
      syncHeroSub();
      window.addEventListener('resize', syncHeroSub);
      if (document.fonts && document.fonts.ready) document.fonts.ready.then(syncHeroSub);

      // ── Copy install ────────────────────────────────
      var btn = document.getElementById('install-copy-btn');
      var label = document.getElementById('install-copy-label');
      if (btn) {
        btn.addEventListener('click', function () {
          navigator.clipboard.writeText(installJoined).then(function () {
            var orig = label.textContent;
            label.textContent = 'Copied!';
            if (window.trackEvent) window.trackEvent('copy_command', 'engagement', 'home_install');
            setTimeout(function () { label.textContent = orig; }, 1500);
          });
        });
      }

      // ── Animated beam ───────────────────────────────
      var wrap = document.getElementById('flow-wrap');
      var svg = document.getElementById('flow-svg');
      var center = document.getElementById('flow-center');
      var sources = document.querySelectorAll('#flow-sources .flow-source');
      var products = document.querySelectorAll('#flow-products .flow-product');
      if (!wrap || !svg || !center || !sources.length || !products.length) return;

      var SVG_NS = 'http://www.w3.org/2000/svg';
      var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      var beamElements = []; // {path, fromEl, toEl, dir} for hover highlighting
      var particles = [];    // {el, path, len, t, speed}
      var rafId = null;
      var lastFrame = 0;
      var paused = false;

      function centerOf(el, wrapRect) {
        var r = el.getBoundingClientRect();
        return {
          x: r.left - wrapRect.left + r.width / 2,
          y: r.top  - wrapRect.top  + r.height / 2,
        };
      }
      function edgePoint(el, wrapRect, side) {
        var r = el.getBoundingClientRect();
        var y = r.top - wrapRect.top + r.height / 2;
        if (side === 'right') return { x: r.right - wrapRect.left, y: y };
        return { x: r.left - wrapRect.left, y: y };
      }
      function makePath(from, to) {
        // Cubic with horizontal tangent control points — clean Magic-UI-style curve.
        var dx = to.x - from.x;
        var c1x = from.x + dx * 0.45;
        var c2x = from.x + dx * 0.55;
        return 'M ' + from.x + ' ' + from.y +
               ' C ' + c1x + ' ' + from.y + ', ' + c2x + ' ' + to.y + ', ' + to.x + ' ' + to.y;
      }

      function rebuild() {
        // Clear previous beams + particles. Use class selectors so polygon arrows
        // (added for outgoing beams) are also removed alongside circle particles.
        Array.prototype.slice.call(svg.querySelectorAll('.flow-beam, .flow-particle')).forEach(function (n) { n.remove(); });
        beamElements = [];
        particles = [];

        var wrapRect = wrap.getBoundingClientRect();
        var centerRight = edgePoint(center, wrapRect, 'right');
        var centerLeft  = edgePoint(center, wrapRect, 'left');
        // Center has its own ring; tie beams to the visual center, not the bounding box edge.
        var centerC = centerOf(center, wrapRect);
        var ringR = 92; // matches .flow-center-ring radius (180px disc) + a touch for the halo
        centerLeft  = { x: centerC.x - ringR, y: centerC.y };
        centerRight = { x: centerC.x + ringR, y: centerC.y };

        // Source → center beams
        sources.forEach(function (el) {
          var from = edgePoint(el, wrapRect, 'right');
          // Aim each source at the ring perimeter, not the dead center, for cleaner visuals
          var to = centerLeft;
          var path = document.createElementNS(SVG_NS, 'path');
          path.setAttribute('class', 'flow-beam');
          path.setAttribute('d', makePath(from, to));
          svg.appendChild(path);
          beamElements.push({ path: path, fromEl: el, toEl: center, dir: 'in' });
        });

        // Center → product beams
        products.forEach(function (el) {
          var from = centerRight;
          var to = edgePoint(el, wrapRect, 'left');
          var path = document.createElementNS(SVG_NS, 'path');
          path.setAttribute('class', 'flow-beam');
          path.setAttribute('d', makePath(from, to));
          svg.appendChild(path);
          beamElements.push({ path: path, fromEl: center, toEl: el, dir: 'out' });
        });

        // Set viewBox to wrap size
        svg.setAttribute('viewBox', '0 0 ' + wrapRect.width + ' ' + wrapRect.height);
        svg.setAttribute('width', wrapRect.width);
        svg.setAttribute('height', wrapRect.height);

        if (prefersReduced) return;

        var groupColors = {
          agent:    { fill: 'var(--accent-blue)', rgb: 'var(--accent-blue-rgb)' },
          provider: { fill: 'var(--green)',       rgb: 'var(--green-rgb)' },
          obs:      { fill: 'var(--amber)',       rgb: '245, 166, 35' },
        };

        // Spawn one particle per beam, staggered, with slightly varied speeds.
        beamElements.forEach(function (beam, i) {
          var p, isArrow = false;
          if (beam.dir === 'in') {
            // Source → TokenJam: circle, colored to match the source tile.
            var group = beam.fromEl.getAttribute('data-group') || 'agent';
            var c = groupColors[group] || groupColors.agent;
            p = document.createElementNS(SVG_NS, 'circle');
            p.setAttribute('class', 'flow-particle');
            p.setAttribute('r', '2.4');
            p.style.fill = c.fill;
            p.style.filter = 'drop-shadow(0 0 4px rgba(' + c.rgb + ', 0.85))';
          } else {
            // TokenJam → product: green arrow, oriented along the path.
            isArrow = true;
            p = document.createElementNS(SVG_NS, 'polygon');
            p.setAttribute('class', 'flow-particle flow-particle--arrow');
            p.setAttribute('points', '-3.5,-3 4.5,0 -3.5,3');
            p.style.fill = 'var(--green)';
            p.style.filter = 'drop-shadow(0 0 4px rgba(var(--green-rgb), 0.85))';
          }
          svg.appendChild(p);
          var len = beam.path.getTotalLength();
          // Stagger initial t so the flow looks ambient, not synchronized.
          var t0 = (i * 0.137 + Math.random() * 0.6) % 1;
          var speed = 0.00018 + Math.random() * 0.00008; // fraction per ms
          particles.push({ el: p, path: beam.path, len: len, t: t0, speed: speed, isArrow: isArrow });
        });
      }

      function animate(now) {
        if (paused || prefersReduced) { rafId = requestAnimationFrame(animate); return; }
        var dt = lastFrame ? (now - lastFrame) : 16;
        lastFrame = now;
        particles.forEach(function (pt) {
          pt.t += pt.speed * dt;
          if (pt.t > 1) pt.t -= 1;
          var s = pt.t * pt.len;
          var pos = pt.path.getPointAtLength(s);
          // Fade in/out at the ends so particles don't pop.
          var alpha = pt.t < 0.08 ? pt.t / 0.08 : (pt.t > 0.92 ? (1 - pt.t) / 0.08 : 1);
          if (pt.isArrow) {
            // Compute path tangent for arrow rotation.
            var ahead = pt.path.getPointAtLength(Math.min(s + 1.5, pt.len));
            var ang = Math.atan2(ahead.y - pos.y, ahead.x - pos.x) * 180 / Math.PI;
            pt.el.setAttribute('transform', 'translate(' + pos.x.toFixed(2) + ',' + pos.y.toFixed(2) + ') rotate(' + ang.toFixed(2) + ')');
          } else {
            pt.el.setAttribute('cx', pos.x);
            pt.el.setAttribute('cy', pos.y);
          }
          pt.el.setAttribute('opacity', alpha.toFixed(2));
        });
        rafId = requestAnimationFrame(animate);
      }

      function start() {
        if (rafId) cancelAnimationFrame(rafId);
        lastFrame = 0;
        rafId = requestAnimationFrame(animate);
      }

      // Pause when off-screen
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) { paused = !e.isIntersecting; });
        }, { threshold: 0.05 });
        io.observe(wrap);
      }

      // Hover highlights — light up beams touching the hovered node
      function highlightFor(el) {
        beamElements.forEach(function (b) {
          var match = b.fromEl === el || b.toEl === el;
          b.path.classList.toggle('is-active', match);
        });
      }
      function clearHighlight() {
        beamElements.forEach(function (b) { b.path.classList.remove('is-active'); });
      }
      [].slice.call(sources).concat([].slice.call(products)).concat([center]).forEach(function (el) {
        el.addEventListener('mouseenter', function () { highlightFor(el); });
        el.addEventListener('mouseleave', clearHighlight);
        el.addEventListener('focusin',  function () { highlightFor(el); });
        el.addEventListener('focusout', clearHighlight);
      });

      // Resize handling
      var rzTimer;
      window.addEventListener('resize', function () {
        clearTimeout(rzTimer);
        rzTimer = setTimeout(function () { rebuild(); }, 120);
      });

      // First paint: wait a tick for fonts/layout to settle so measurements are correct.
      requestAnimationFrame(function () {
        rebuild();
        start();
      });
      // Re-measure once webfonts finish loading (Geist arrives after first paint and shifts text by a few px).
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(function () { rebuild(); });
      }
    })();
  </script>
</BaseLayout>
