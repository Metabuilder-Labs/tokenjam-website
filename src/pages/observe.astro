---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { products as productCatalog, productIcons } from '@/data/products';

// Per-analyzer accent (single source of truth in src/data/products.ts).
const accentBySlug = Object.fromEntries(
  productCatalog.map((p) => [p.slug, { accent: p.accent, accentRgb: p.accentRgb }])
);

// Inline SVGs for the six observability features. Same metaphors as the
// homepage strip; tones applied via `data-tone` attribute (see CSS).
const featureIcons: Record<string, string> = {
  cost:   `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  trace:  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="14" height="3" rx="1"/><rect x="6" y="10" width="14" height="3" rx="1"/><rect x="3" y="16" width="11" height="3" rx="1"/></svg>`,
  alert:  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>`,
  drift:  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
  schema: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M9 14l2 2 4-4"/></svg>`,
  ui:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M8 21h8M12 18v3M7 9h2M7 12h4"/></svg>`,
};

// Six observability features. Each is a real shipped capability backed by
// the OSS CLI today. Keep the copy honest — no claims about features that
// only the cloud version (whenever it lands) will have.
const features = [
  {
    name: 'Real-time cost tracking',
    body: "Every LLM call is priced as it happens using TokenJam's local pricing table. Spend breaks down by agent, model, session, and tool. Budget alerts fire before you hit the limit, not after.",
    cmd: 'tj cost --since 7d',
    icon: featureIcons.cost,
    tone: 'green',
  },
  {
    name: 'Trace waterfalls',
    body: "Every session is captured as a full OpenTelemetry span tree. See which tools ran, in what order, with what arguments, and how long each step took, in the local web UI or the CLI.",
    cmd: 'tj traces',
    icon: featureIcons.trace,
    tone: 'blue',
  },
  {
    name: 'Sensitive-action alerts',
    body: "Configure any tool call as a sensitive action (send_email, delete_file, submit_form) and get notified instantly. 13 alert types, 6 channels: ntfy push (free, phone-friendly), Discord, Telegram, webhook, file, stdout.",
    cmd: 'tj alerts',
    icon: featureIcons.alert,
    tone: 'red',
  },
  {
    name: 'Behavioral drift detection',
    body: "TokenJam builds a Z-score baseline from your agent's real behavior (token counts, tool sequences, output shapes). When something drifts (a prompt tweak, a model update, a dep bump), you get a drift_detected alert at session end. No LLM-on-LLM evaluation required.",
    cmd: 'tj drift',
    icon: featureIcons.drift,
    tone: 'amber',
  },
  {
    name: 'Schema validation',
    body: "Declare a JSON Schema for any tool's output or let TokenJam infer one from a few sessions. Schema violations are caught at ingest and surface as schema_violation alerts.",
    cmd: 'tj tools',
    icon: featureIcons.schema,
    tone: 'invert-light',
  },
  {
    name: 'Local web UI + REST API',
    body: "`tj serve` runs a local dashboard at 127.0.0.1:7391 with status, traces, cost breakdown, alerts, budget, and drift. Prometheus metrics at /metrics. No cloud, no signup, runs entirely on your machine.",
    cmd: 'tj serve',
    icon: featureIcons.ui,
    tone: 'invert-dark',
  },
];

// Powers-the-analyzers list. The point of this section: observability isn't
// a bolt-on. It's the substrate the five analyzers ride on. Each analyzer
// needs particular telemetry shapes that the observability stack collects.
const analyzerLinks = [
  { slug: 'downsize', name: 'Downsize', needs: 'token counts, tool-call shape, session classification' },
  { slug: 'cache',    name: 'Cache',    needs: 'captured prompts and prefix-stability tracking' },
  { slug: 'script',   name: 'Script',   needs: 'tool-name + argument-shape signatures per session' },
  { slug: 'trim',     name: 'Trim',     needs: 'captured prompt content for token-significance scoring' },
  { slug: 'reuse',    name: 'Reuse',    needs: 'plan-skeleton clustering across completed sessions' },
];
---
<BaseLayout
  title="Observability — TokenJam"
  description="TokenJam ships a full local-first observability stack: traces, real-time cost tracking, sensitive-action alerts, behavioral drift detection, schema validation, web UI, REST API. Free, open-source, MIT-licensed."
  wide
>
  <main class="tj-main">
    <article class="observe-page">

      <!-- HERO -->
      <header class="observe-hero">
        <p class="observe-hero-eyebrow">Observability</p>
        <h1 class="observe-hero-h1">The observability stack the analyzers ride on</h1>
        <p class="observe-hero-sub">
          Most people meet TokenJam through cost optimization. Underneath is a full local-first
          observability tool for AI agents: traces, drift, alerts, budgets, schema validation, and a web UI.
          The five analyzers ride on top of this substrate. Free, open-source, MIT-licensed.
        </p>
        <div class="observe-hero-ctas">
          <a href="/#install" class="btn-primary btn-lg">Get started</a>
          <a href="https://github.com/metabuilder-labs/tokenjam" target="_blank" rel="noopener noreferrer" class="btn-secondary btn-lg">View on GitHub</a>
        </div>
      </header>

      <!-- FEATURE LIST -->
      <section class="observe-features-section">
        <header class="section-head">
          <h2 class="section-h2">What's included</h2>
          <p class="section-lede">
            Six capabilities. All shipping in the open-source CLI today.
          </p>
        </header>
        <ul class="observe-features-list">
          {features.map((f) => (
            <li class="observe-feature" data-tone={f.tone}>
              <span class="observe-feature-icon" aria-hidden="true" set:html={f.icon}></span>
              <div class="observe-feature-body">
                <h3>{f.name}</h3>
                <p>{f.body}</p>
              </div>
              <code class="observe-feature-cmd">{f.cmd}</code>
            </li>
          ))}
        </ul>
      </section>

      <!-- HOW IT POWERS THE ANALYZERS -->
      <section class="observe-bridge-section">
        <header class="section-head">
          <h2 class="section-h2">It's also what powers the analyzers</h2>
          <p class="section-lede">
            Each analyzer needs a particular shape of telemetry. The observability stack is
            what collects it, so the analyzers can run against your real usage instead of a
            synthetic benchmark.
          </p>
        </header>
        <div class="observe-bridge-grid">
          {analyzerLinks.map((a) => {
            const c = accentBySlug[a.slug] ?? { accent: '#94A3B8', accentRgb: '148, 163, 184' };
            const icon = productIcons[a.slug as keyof typeof productIcons] ?? '';
            return (
              <a
                href={`/products/${a.slug}`}
                class="observe-bridge-card"
                style={`--product-accent: ${c.accent}; --product-accent-rgb: ${c.accentRgb};`}
              >
                <span class="observe-bridge-icon" aria-hidden="true" set:html={icon}></span>
                <h3>{a.name}</h3>
                <p>Needs {a.needs}.</p>
                <span class="observe-bridge-arrow" aria-hidden="true">→</span>
              </a>
            );
          })}
        </div>
      </section>

      <!-- LOCAL-FIRST CALLOUT -->
      <section class="observe-local-section">
        <h2>Local-first, by design.</h2>
        <p>
          Your spans contain prompts, completions, tool inputs, and customer data. Shipping
          that to a SaaS observability vendor is a data-egress decision most teams aren't
          ready to make. TokenJam captures, stores, and analyzes everything on your machine:
          DuckDB on disk, REST API on <code>127.0.0.1</code>, no telemetry leaving by default.
        </p>
        <p>
          When you do want to forward telemetry (to Grafana, Datadog, an OTLP collector),
          <code>tj export</code> ships it on your terms.
        </p>
      </section>

    </article>
  </main>

  <style>
    .observe-page {
      max-width: 1080px;
      margin: 0 auto;
      padding: calc(60px + var(--banner-h, 0px)) 24px 96px;
    }

    /* HERO */
    .observe-hero {
      text-align: center;
      max-width: 760px;
      margin: 0 auto 80px;
    }
    .observe-hero-eyebrow {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 999px;
      background: rgba(var(--accent-blue-rgb), 0.12);
      color: var(--accent-blue);
      font-family: 'Geist Mono', monospace;
      font-size: 11px;
      letter-spacing: .1em;
      text-transform: uppercase;
      margin: 0 0 18px;
    }
    .observe-hero-h1 {
      font-family: 'Geist', sans-serif;
      font-size: clamp(32px, 4.5vw, 52px);
      font-weight: 600;
      letter-spacing: -0.02em;
      line-height: 1.08;
      margin: 0 0 18px;
    }
    .observe-hero-sub {
      font-family: 'Geist', sans-serif;
      font-size: clamp(16px, 1.5vw, 18px);
      line-height: 1.55;
      color: var(--white-faint);
      margin: 0 auto 28px;
    }
    .observe-hero-ctas {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* FEATURES */
    .observe-features-section { margin-bottom: 96px; }
    .observe-features-list {
      list-style: none;
      padding: 0;
      margin: 36px 0 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
    .observe-feature {
      padding: 24px 26px;
      background: var(--navy-2);
      border: 1px solid var(--blue-line);
      border-radius: 12px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .observe-feature-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: var(--white-ghost);
      color: var(--white);
      flex-shrink: 0;
    }
    .observe-feature-icon svg { width: 22px; height: 22px; }
    /* Match the homepage strip tones so feature identity is consistent across surfaces. */
    .observe-feature[data-tone="green"] .observe-feature-icon { background: rgba(34, 197, 94, 0.14); color: #22C55E; }
    .observe-feature[data-tone="blue"]  .observe-feature-icon { background: rgba(59, 130, 246, 0.14); color: #3B82F6; }
    .observe-feature[data-tone="red"]   .observe-feature-icon { background: rgba(239, 68, 68, 0.14); color: #EF4444; }
    .observe-feature[data-tone="amber"] .observe-feature-icon { background: rgba(245, 158, 11, 0.16); color: #F59E0B; }
    .observe-feature[data-tone="invert-light"] .observe-feature-icon { background: var(--white); color: var(--navy); }
    .observe-feature[data-tone="invert-dark"]  .observe-feature-icon { background: var(--navy); color: var(--white); border: 1px solid var(--blue-line); }
    .observe-feature h3 {
      font-family: 'Geist', sans-serif;
      font-size: 17px;
      font-weight: 600;
      letter-spacing: -0.005em;
      margin: 0 0 8px;
      color: var(--white);
    }
    .observe-feature p {
      font-family: 'Geist', sans-serif;
      font-size: 14.5px;
      line-height: 1.6;
      color: var(--white-faint);
      margin: 0;
    }
    .observe-feature-cmd {
      align-self: flex-start;
      font-family: 'Geist Mono', monospace;
      font-size: 12.5px;
      padding: 6px 10px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--blue-line);
      border-radius: 6px;
      color: var(--white);
    }
    @media (max-width: 820px) {
      .observe-features-list { grid-template-columns: 1fr; }
    }

    /* BRIDGE — links to analyzers */
    .observe-bridge-section { margin-bottom: 96px; }
    .observe-bridge-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
      margin-top: 36px;
    }
    .observe-bridge-card {
      position: relative;
      display: block;
      padding: 22px 26px;
      background: var(--navy-2);
      border: 1px solid var(--blue-line);
      border-top: 2px solid var(--product-accent, var(--blue-line));
      border-radius: 12px;
      text-decoration: none;
      transition: border-color 160ms ease, transform 160ms ease, box-shadow 160ms ease;
    }
    .observe-bridge-card:hover {
      transform: translateY(-2px);
      border-color: rgba(var(--product-accent-rgb), 0.35);
      border-top-color: var(--product-accent);
      box-shadow: 0 10px 24px rgba(var(--product-accent-rgb), 0.10);
    }
    .observe-bridge-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: rgba(var(--product-accent-rgb), 0.12);
      color: var(--product-accent);
      margin-bottom: 12px;
    }
    .observe-bridge-icon svg { width: 18px; height: 18px; }
    .observe-bridge-card h3 {
      font-family: 'Geist', sans-serif;
      font-size: 17px;
      font-weight: 600;
      margin: 0 0 6px;
      color: var(--product-accent, var(--white));
    }
    .observe-bridge-card p {
      font-family: 'Geist', sans-serif;
      font-size: 14px;
      line-height: 1.55;
      color: var(--white-faint);
      margin: 0;
    }
    .observe-bridge-arrow {
      position: absolute;
      top: 24px;
      right: 26px;
      color: var(--product-accent, var(--white-faint));
      font-family: 'Geist Mono', monospace;
      font-size: 16px;
      transition: transform .15s;
    }
    .observe-bridge-card:hover .observe-bridge-arrow { transform: translateX(3px); }
    @media (max-width: 820px) {
      .observe-bridge-grid { grid-template-columns: 1fr; }
    }

    /* LOCAL-FIRST */
    .observe-local-section {
      max-width: 760px;
      margin: 0 auto;
      text-align: center;
    }
    .observe-local-section h2 {
      font-family: 'Geist', sans-serif;
      font-size: clamp(22px, 2.6vw, 30px);
      font-weight: 600;
      letter-spacing: -0.015em;
      margin: 0 0 18px;
    }
    .observe-local-section p {
      font-family: 'Geist', sans-serif;
      font-size: 16px;
      line-height: 1.65;
      color: var(--white-faint);
      margin: 0 0 14px;
    }
    .observe-local-section code {
      font-family: 'Geist Mono', monospace;
      font-size: 0.92em;
      padding: 2px 6px;
      background: rgba(255, 255, 255, 0.06);
      border-radius: 4px;
      color: var(--white);
    }
  </style>
</BaseLayout>
