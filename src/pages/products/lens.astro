---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getProduct, productIcons } from '@/data/products';
import Browser from '@/components/Browser.astro';
import Callout from '@/components/Callout.astro';

const product = getProduct('lens')!;
---
<BaseLayout
  title={`TokenJam ${product.name} — ${product.heroClaim}`}
  description={`${product.heroClaim} ${product.shortBlurb}`}
  wide
>
  <article
    class="pp"
    style={`--product-accent: ${product.accent}; --product-accent-rgb: ${product.accentRgb};`}
  >
    <!-- HERO -->
    <header class="pp-hero">
      <span class="pp-name-icon" aria-hidden="true" set:html={productIcons['lens']}></span>
      <h1 class="pp-name">
        <span class="pp-name-brand">TokenJam</span>
        <span class="pp-name-product">{product.name}</span>
      </h1>
      <p class="pp-claim">{product.heroClaim}</p>
      <p class="pp-sub">
        The heart of Lens is its explorer: one pivot — <strong>metric × dimension × chart</strong> —
        that slices spend, tokens, and tool calls every way you need, with one-click presets and CSV
        export. It's the dashboard you get from <code>tj serve</code>: runs entirely on your machine,
        no signup, no cloud.
      </p>
      <div class="pp-hero-ctas">
        <a href="/#install" class="btn-primary">Get started</a>
        <a href="https://github.com/metabuilder-labs/tokenjam" target="_blank" rel="noopener noreferrer" class="btn-secondary">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
          GitHub
        </a>
      </div>
      <div class="lens-screenshot lens-hero-shot">
        <Browser url="127.0.0.1:7391/#/dashboard">
          <img class="lens-shot" src="/products/lens/tj-dashboard.png" width="1089" height="1100" loading="eager" alt="TokenJam Lens dashboard — recoverable-waste triage tiles, health-at-a-glance, and the embedded explorer with a spend-by-model chart" />
        </Browser>
      </div>
    </header>

    <!-- SCREENSHOT A — the explorer -->
    <section class="pp-section">
      <h2 class="pp-h2">One chart, every slice</h2>
      <p class="pp-section-lede">
        Static cost dashboards give you the views their authors thought of. Lens gives you the pivot.
        Pick a <strong>metric</strong> (spend, tokens, events), a <strong>dimension</strong> (model,
        tool, agent, time), and a <strong>chart</strong> (bars, lines, leaderboard) — then read the
        answer. Presets like <em>Spend by model</em>, <em>Cost leaderboard</em>, <em>Tokens over
        time</em>, and <em>Tool usage</em> are one click; <strong>Export CSV</strong> drops the same
        slice into your own tooling. It's the same explorer the Analytics tab opens full-screen.
      </p>
      <div class="lens-duo">
        <figure class="lens-fig">
          <div class="lens-screenshot">
            <Browser url="127.0.0.1:7391/#/dashboard">
              <img class="lens-shot" src="/products/lens/tj-dashboard-leaderboard.png" width="1211" height="1013" loading="lazy" alt="Lens explorer configured as a spend-by-model leaderboard over the last 90 days" />
            </Browser>
          </div>
          <figcaption>Spend × Model, ranked — where the tokens actually concentrate.</figcaption>
        </figure>
        <figure class="lens-fig">
          <div class="lens-screenshot">
            <Browser url="127.0.0.1:7391/#/dashboard">
              <img class="lens-shot" src="/products/lens/tj-dashboard-tools.png" width="1116" height="895" loading="lazy" alt="Lens explorer configured as a tool-usage leaderboard by event count" />
            </Browser>
          </div>
          <figcaption>Events × Tool category — same pivot, a completely different question.</figcaption>
        </figure>
      </div>
    </section>

    <!-- SCREENSHOT B — Dashboard / triage -->
    <section class="pp-section">
      <h2 class="pp-h2">Your triage front door</h2>
      <p class="pp-section-lede">
        The Dashboard is the default landing view — what used to be a separate Overview page is now
        merged in, so the first screen answers "where am I, and what should I look at next?" A
        <strong>recoverable-waste</strong> band carries one tile per analyzer (Downsize, Cache,
        Script, Reuse, Trim), each tagged <em>Estimated</em> and showing its finding or
        <code>✓ 100% cache efficacy</code> when there's nothing to recover. A
        <strong>health-at-a-glance</strong> row covers unread alerts, agents drifting from baseline,
        budgets at risk, and recent activity. Every waste tile drills into its detail in place — no
        page hop — and the explorer sits right below it. New analyzers appear automatically: the band
        is registry-driven.
      </p>
    </section>

    <!-- SCREENSHOT C — Cost -->
    <section class="pp-section">
      <h2 class="pp-h2">Cost, with the math shown</h2>
      <p class="pp-section-lede">
        Spend over time as a real chart, paired with a <strong>Caching</strong> card so a
        cache-heavy window is no longer a mystery: cache hit-rate, cached reads, and per-day cached
        volume, with the reminder that cached input bills at roughly a tenth of the normal rate. The
        per-day table breaks input, output, <code>CACHE R</code>, <code>CACHE W</code>, and total
        cost down by agent or model. Projections are captioned
        <em>"linear run-rate, not a forecast"</em> — Lens never claims to predict.
      </p>
      <div class="lens-screenshot">
        <Browser url="127.0.0.1:7391/#/cost">
          <img class="lens-shot" src="/products/lens/tj-cost.png" width="1062" height="1015" loading="lazy" alt="Lens cost page — spend-over-time chart, caching card, and the per-day cost table in tokens" />
        </Browser>
      </div>
    </section>

    <!-- SCREENSHOT D — Traces -->
    <section class="pp-section">
      <h2 class="pp-h2">Trace any session down to the span</h2>
      <p class="pp-section-lede">
        Open a session for the <strong>cost-annotated waterfall</strong>: every span laid out by
        magnitude (toggle by tokens or by duration), with a per-span cost column. Hover a span and
        you get the call detail — provider, model, input/output tokens, and cache read/write — so the
        expensive span in a long run is obvious at a glance.
      </p>
      <div class="lens-screenshot">
        <Browser url="127.0.0.1:7391/#/traces">
          <img class="lens-shot" src="/products/lens/tj-traces.png" width="1133" height="1033" loading="lazy" alt="Lens traces page — cost-annotated span waterfall with per-span token detail on hover" />
        </Browser>
      </div>
    </section>

    <!-- HONESTY CALLOUT -->
    <section class="pp-section">
      <Callout type="tip">
        <p><strong>Lens runs entirely on your machine.</strong> No data leaves it, not even to
        TokenJam — the dashboard works fully offline. Every recoverable-waste figure is an honest
        heuristic estimate, never a promise. If you're on a flat-rate subscription (Claude Max,
        ChatGPT Plus), Lens reports your usage as a <strong>× plan value</strong> multiple — what the
        same tokens would cost at on-demand API rates. A heavy Max user can see their usage is worth
        20–30× their subscription fee. It's implied value, never money you spent.</p>
      </Callout>
    </section>

    <!-- GET STARTED -->
    <section class="pp-section">
      <h2 class="pp-h2">Get started</h2>
      <p class="pp-section-lede">
        Local, no signup. <code>tj onboard</code> backfills your last 30 days of Claude Code
        sessions, so the dashboard is full of <em>your own</em> data the moment it opens at
        <code>127.0.0.1:7391</code>.
      </p>
      <div class="terminal pp-terminal">
        <div class="terminal-titlebar">
          <span class="dot dot-r"></span>
          <span class="dot dot-y"></span>
          <span class="dot dot-g"></span>
          <span class="terminal-title">install</span>
        </div>
        <pre class="terminal-body pp-terminal-body">
<span class="tline"><span class="t-prompt">$ </span><span class="t-cmd">pipx install tokenjam</span></span>
<span class="tline"><span class="t-prompt">$ </span><span class="t-cmd">tj onboard --claude-code</span></span>
<span class="tline t-dim">  → backfills your last 30 days of Claude Code sessions</span>
<span class="tline"><span class="t-prompt">$ </span><span class="t-cmd">tj serve</span></span>
<span class="tline t-dim">  → open http://127.0.0.1:7391/</span></pre>
      </div>
      <p class="pp-fineprint">
        Curious where you land first? <a href="/tokenmaxxing">Are you TokenMaxxing hard enough?</a> —
        find your tier in under a minute. Source on
        <a href="https://github.com/metabuilder-labs/tokenjam" target="_blank" rel="noopener noreferrer">GitHub</a>;
        full <a href="/docs/web-ui">Web UI reference</a> in the docs.
      </p>
    </section>
  </article>

  <style>
    /* Lens-specific scoped styles. The .pp-* shell styles come from
       [slug].astro's scope but those are scoped CIDs — re-declare what
       we need here so the Lens page stands on its own. */
    .pp { max-width: 980px; margin: 0 auto; padding: calc(72px + var(--banner-h, 0px)) 24px 96px; }
    .pp-hero { text-align: center; margin-bottom: 56px; }
    .pp-name-icon {
      display: inline-flex;
      align-items: center; justify-content: center;
      width: 52px; height: 52px;
      border-radius: 12px;
      background: rgba(var(--product-accent-rgb), 0.12);
      color: var(--product-accent);
      margin-bottom: 20px;
    }
    .pp-name-icon svg { width: 28px; height: 28px; }
    .pp-name {
      font-family: 'Geist', sans-serif;
      font-weight: 700;
      letter-spacing: -.04em;
      line-height: 1;
      font-size: clamp(48px, 7vw, 96px);
      margin: 0 0 20px;
      display: flex; justify-content: center; flex-wrap: wrap;
      gap: 0.22em;
    }
    .pp-name-brand   { color: var(--white); }
    .pp-name-product { color: var(--product-accent); }
    .pp-claim {
      font-family: 'Geist', sans-serif;
      font-weight: 500;
      letter-spacing: -.015em;
      line-height: 1.2;
      font-size: clamp(20px, 2vw, 26px);
      color: var(--white);
      margin: 0 auto 16px;
      max-width: 760px;
    }
    .pp-sub {
      color: var(--white-dim);
      font-size: 17px;
      line-height: 1.6;
      max-width: 680px;
      margin: 0 auto 28px;
    }
    .pp-sub strong { color: var(--white); font-weight: 600; }
    .pp-sub code, .pp-section-lede code, .pp-fineprint code {
      font-family: 'Geist Mono', monospace;
      font-size: .9em;
      padding: 1px 6px;
      background: var(--white-ghost);
      border-radius: 4px;
      color: var(--white);
    }
    .pp-hero-ctas {
      display: flex; justify-content: center; gap: 12px; flex-wrap: wrap;
    }
    .pp-section {
      padding-top: 56px;
      border-top: 1px solid var(--blue-line);
      margin-top: 56px;
    }
    .pp-h2 {
      font-family: 'Geist', sans-serif;
      font-weight: 600;
      letter-spacing: -.015em;
      font-size: clamp(24px, 2.6vw, 30px);
      color: var(--white);
      margin: 0 0 16px;
    }
    .pp-section-lede {
      color: var(--white-dim);
      font-size: 16px;
      line-height: 1.6;
      margin: 0 0 24px;
      max-width: 760px;
    }
    .pp-section-lede strong { color: var(--white); font-weight: 600; }
    .pp-section-lede em { color: var(--white); font-style: normal; font-weight: 500; }
    .pp-fineprint {
      color: var(--white-faint);
      font-size: 13px;
      margin: 16px 0 0;
    }
    .pp-fineprint a {
      color: var(--accent-blue);
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .pp-terminal { margin-top: 4px; }
    .pp-terminal-body { padding: 18px 22px; margin: 0; }

    /* Real-screenshot blocks: a Browser frame wrapping a full-bleed PNG.
       Zero the frame's body padding so the capture sits flush under the
       title bar (the synthetic mock used padding; images don't want it). */
    .lens-screenshot { margin-top: 4px; }
    .lens-hero-shot { margin-top: 40px; text-align: left; }
    .pp :global(.browser-body) { padding: 0; }
    .lens-shot { display: block; width: 100%; height: auto; }

    /* Side-by-side explorer variants; stacks on narrow screens. */
    .lens-duo {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-top: 4px;
    }
    .lens-fig { margin: 0; }
    .lens-fig figcaption {
      margin-top: 12px;
      font-size: 13.5px;
      line-height: 1.5;
      color: var(--white-dim);
    }
    @media (max-width: 720px) {
      .lens-duo { grid-template-columns: 1fr; gap: 28px; }
    }
  </style>
</BaseLayout>
