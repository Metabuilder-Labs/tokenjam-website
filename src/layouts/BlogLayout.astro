---
import BaseLayout from './BaseLayout.astro';
import Schema from '@/components/Schema.astro';
import { getAuthor } from '@/lib/authors';
import { articleSchema } from '@/lib/schema';
import { readingTimeMinutes, relatedPosts, getPublishedPosts, type BlogPost } from '@/lib/blog';
import { getStarCount, formatStars, ghUrl } from '@/lib/github';

const starLabel = formatStars(await getStarCount());
const postStarHref = ghUrl('blog');

interface Props {
  post: BlogPost;
}
const { post } = Astro.props;
const author = getAuthor(post.data.author) ?? getAuthor('anil-murty');
const minutes = readingTimeMinutes(post.body);

const all = await getPublishedPosts();
const related = relatedPosts(post, all, 3);

const dateOpts: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'short', day: 'numeric' };
const fmt = (d: Date) => d.toLocaleDateString('en-US', dateOpts);

const canonical = post.data.canonicalUrl;
const imageUrl = post.data.image ?? '/og-image.png';
---
<BaseLayout
  title={`${post.data.title} — TokenJam`}
  description={post.data.description}
  image={imageUrl}
  type="article"
  canonical={canonical}
>
  <article>
    <header class="article-header">
      <h1>{post.data.title}</h1>
      <div class="article-byline">
        {author && <a href={`/blog/authors/${author.slug}`}>{author.name}</a>}
        <span>·</span>
        <time datetime={post.data.publishDate.toISOString()}>{fmt(post.data.publishDate)}</time>
        {post.data.lastUpdated && (
          <>
            <span>·</span>
            <span>Updated {fmt(post.data.lastUpdated)}</span>
          </>
        )}
        <span>·</span>
        <span>{minutes} min read</span>
        {post.data.pillar && (
          <>
            <span>·</span>
            <span class="post-pillar">{post.data.pillar}</span>
          </>
        )}
      </div>
    </header>

    {post.data.image && (
      <img
        src={post.data.image}
        alt={post.data.title}
        class="article-cover"
        loading="eager"
      />
    )}

    <div class="prose">
      <slot />
    </div>

    {/* Star-on-GitHub CTA shown at the end of every post. Asks for the star
        when the reader has just gotten value from the content. */}
    <aside class="post-star-cta">
      <div class="post-star-cta-text">
        <strong>Found this useful?</strong>
        <span>TokenJam is open-source and MIT-licensed. A star helps more developers find it.</span>
      </div>
      <a
        href={postStarHref}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary post-star-cta-btn"
        onclick="window.trackEvent && window.trackEvent('cta_click', 'conversion', 'star_github_blog_post')"
      >
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z"/></svg>
        Star on GitHub<span class="post-star-cta-count" data-star-count-prefixed>{starLabel ? `· ${starLabel}` : ''}</span>
      </a>
    </aside>

    {post.data.tags.length > 0 && (
      <div class="chip-row" style="margin-top: 32px;">
        {post.data.tags.map((tag) => (
          <a href={`/blog/tags/${tag}`} class="chip">#{tag}</a>
        ))}
      </div>
    )}

    {related.length > 0 && (
      <section class="related-posts">
        <h3>Related</h3>
        <ul>
          {related.map((p) => (
            <li><a href={`/blog/${p.id}`}>{p.data.title}</a></li>
          ))}
        </ul>
      </section>
    )}
  </article>

  <Schema data={articleSchema(post)} />
</BaseLayout>
