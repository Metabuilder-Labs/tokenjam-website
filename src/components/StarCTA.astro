---
/*
 * Reusable "Star on GitHub" call-to-action for blog posts. Rendered both right
 * after the TL;DR (tight) and at the foot of every post. Links to the org
 * repositories list so readers can star every TokenJam repo.
 */
import { ghReposUrl } from '@/lib/github';
interface Props {
  /** Smaller top margin for the in-flow placement right after the TL;DR. */
  tight?: boolean;
}
const { tight = false } = Astro.props;
const href = ghReposUrl('blog');
---
<aside class:list={['post-star-cta', tight && 'post-star-cta--tight']}>
  <div class="post-star-cta-text">
    <strong>Found this useful?</strong>
    <span>TokenJam is open-source and MIT-licensed. A star helps more developers find it.</span>
  </div>
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class="btn-primary post-star-cta-btn"
    onclick="window.trackEvent && window.trackEvent('cta_click', 'conversion', 'star_github_blog_post')"
  >
    <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z"/></svg>
    Star on GitHub
  </a>
</aside>
