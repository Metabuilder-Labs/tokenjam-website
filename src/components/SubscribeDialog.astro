---
/*
 * Site-wide email subscribe dialog. Rendered once from BaseLayout so any
 * page can trigger it via an element with `data-subscribe-open`.
 *
 *   <button type="button" data-subscribe-open>Sign up</button>
 *
 * Submits to /api/waitlist (Vercel serverless function -> Resend Audience).
 */
---
<dialog id="subscribe-dialog" class="subscribe-dialog">
  <form id="subscribe-form" class="subscribe-form" novalidate>
    <button type="button" class="subscribe-close" id="subscribe-close" aria-label="Close">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h2>Get TokenJam updates</h2>
    <p class="subscribe-desc">Occasional updates on new features, benchmarks, and posts. No spam, unsubscribe anytime.</p>
    <label class="subscribe-field">
      <span class="sr-only">Email address</span>
      <input id="subscribe-email" type="email" name="email" required autocomplete="email" placeholder="you@example.com" />
    </label>
    <button type="submit" class="btn-primary subscribe-submit" id="subscribe-submit">Subscribe</button>
    <p class="subscribe-msg" id="subscribe-msg" role="status" aria-live="polite"></p>
  </form>
</dialog>

<style is:global>
  .subscribe-dialog {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(420px, calc(100vw - 32px));
    max-width: none;
    margin: 0;
    padding: 0;
    border: 1px solid var(--blue-line);
    border-radius: 14px;
    background: var(--navy-2);
    color: var(--white);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5);
  }
  .subscribe-dialog::backdrop { background: rgba(0, 0, 0, 0.55); backdrop-filter: blur(4px); }
  .subscribe-dialog[open] { animation: subscribe-pop .18s ease-out; }
  @keyframes subscribe-pop {
    from { opacity: 0; transform: translate(-50%, calc(-50% + 8px)); }
    to   { opacity: 1; transform: translate(-50%, -50%); }
  }
  .subscribe-form {
    position: relative;
    display: flex; flex-direction: column;
    gap: 14px;
    padding: 28px 28px 24px;
  }
  .subscribe-close {
    position: absolute; top: 12px; right: 12px;
    width: 32px; height: 32px;
    display: inline-flex; align-items: center; justify-content: center;
    background: transparent;
    border: 0;
    border-radius: 6px;
    color: var(--white-faint);
    cursor: pointer;
    transition: color .15s, background-color .15s;
  }
  .subscribe-close:hover { color: var(--white); background: var(--white-ghost); }
  .subscribe-form h2 {
    font-family: 'Geist', sans-serif;
    font-size: 20px; font-weight: 600; letter-spacing: -.01em;
    margin: 0; color: var(--white);
  }
  .subscribe-desc {
    color: var(--white-dim);
    font-size: 14px; line-height: 1.5;
    margin: 0;
  }
  .subscribe-field input {
    width: 100%;
    padding: 11px 14px;
    font-family: 'Geist', sans-serif;
    font-size: 14px;
    color: var(--white);
    background: var(--navy);
    border: 1px solid var(--blue-line);
    border-radius: 8px;
    outline: none;
    transition: border-color .15s, box-shadow .15s;
  }
  .subscribe-field input::placeholder { color: var(--white-faint); }
  .subscribe-field input:focus {
    border-color: rgba(var(--accent-blue-rgb), 0.6);
    box-shadow: 0 0 0 3px rgba(var(--accent-blue-rgb), 0.18);
  }
  .subscribe-submit { width: 100%; justify-content: center; padding: 11px 16px; font-size: 14px; }
  .subscribe-msg {
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    margin: 0;
    min-height: 18px;
    color: var(--white-faint);
  }
  .subscribe-msg-ok    { color: var(--green); }
  .subscribe-msg-error { color: var(--red); }
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
</style>

<script is:inline>
  (function () {
    var dlg = document.getElementById('subscribe-dialog');
    var closeBtn = document.getElementById('subscribe-close');
    var form = document.getElementById('subscribe-form');
    var msg = document.getElementById('subscribe-msg');
    var submit = document.getElementById('subscribe-submit');
    var emailInput = document.getElementById('subscribe-email');
    if (!dlg || !form) return;

    function showMsg(text, kind) {
      msg.textContent = text;
      msg.className = 'subscribe-msg' + (kind ? ' subscribe-msg-' + kind : '');
    }
    function open(triggerLabel) {
      showMsg('');
      if (typeof dlg.showModal === 'function') dlg.showModal();
      else dlg.setAttribute('open', '');
      setTimeout(function () { emailInput && emailInput.focus(); }, 30);
      if (window.trackEvent) window.trackEvent('cta_click', 'conversion', 'subscribe_open_' + (triggerLabel || 'unknown'));
    }

    // Any element with [data-subscribe-open] opens the dialog. The attribute
    // value (e.g. data-subscribe-open="hero") is forwarded as the analytics label.
    document.querySelectorAll('[data-subscribe-open]').forEach(function (el) {
      el.addEventListener('click', function (e) {
        e.preventDefault();
        open(el.getAttribute('data-subscribe-open') || 'unknown');
      });
    });

    closeBtn && closeBtn.addEventListener('click', function () { dlg.close(); });
    dlg.addEventListener('click', function (e) {
      // Backdrop click closes (dialog itself is the click target when backdrop is hit).
      var r = dlg.getBoundingClientRect();
      if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) {
        dlg.close();
      }
    });

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var email = (emailInput.value || '').trim();
      if (!email || email.indexOf('@') === -1) {
        showMsg('Enter a valid email.', 'error');
        return;
      }
      submit.disabled = true;
      showMsg('Submitting…');
      fetch('/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email })
      }).then(function (res) {
        return res.json().catch(function () { return {}; }).then(function (data) {
          return { ok: res.ok, data: data };
        });
      }).then(function (r) {
        submit.disabled = false;
        if (r.ok) {
          showMsg("Thanks — you're on the list.", 'ok');
          form.reset();
          if (window.trackEvent) window.trackEvent('subscribe_success', 'conversion', 'dialog');
          setTimeout(function () { dlg.close(); }, 1600);
        } else {
          showMsg((r.data && r.data.error) || 'Something went wrong.', 'error');
        }
      }).catch(function () {
        submit.disabled = false;
        showMsg('Network error. Please try again.', 'error');
      });
    });
  })();
</script>
