---
import Logo from './Logo.astro';
---
<footer class="tj-footer">
  <div class="footer-left">
    <Logo class="footer-logo brand-logo" />
    <div class="footer-meta">
      <span class="license-badge">MIT</span>
      <a href="https://github.com/metabuilder-labs/tokenjam" target="_blank" rel="noopener noreferrer" onclick="window.trackEvent && window.trackEvent('cta_click', 'conversion', 'view_on_github_footer')">GitHub ↗</a>
      <a href="https://pypi.org/project/tokenjam/" target="_blank" rel="noopener noreferrer" onclick="window.trackEvent && window.trackEvent('outbound_click', 'engagement', 'pypi_footer')">PyPI ↗</a>
      <a href="https://www.npmjs.com/package/@tokenjam/sdk" target="_blank" rel="noopener noreferrer" onclick="window.trackEvent && window.trackEvent('outbound_click', 'engagement', 'npm_footer')">npm ↗</a>
      <a href="https://www.linkedin.com/company/tokenjam/" target="_blank" rel="noopener noreferrer" onclick="window.trackEvent && window.trackEvent('outbound_click', 'engagement', 'linkedin_footer')">LinkedIn ↗</a>
      <a href="https://x.com/tokenjamdev" target="_blank" rel="noopener noreferrer" onclick="window.trackEvent && window.trackEvent('outbound_click', 'engagement', 'x_footer')">X ↗</a>
      <a href="/about" onclick="window.trackEvent && window.trackEvent('nav_click', 'engagement', 'about_footer')">About</a>
    </div>
  </div>
  <div class="footer-right">
    A Metabuilder Labs Product
  </div>
</footer>
