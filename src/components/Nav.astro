---
import Logo from './Logo.astro';
import { products as productCatalog, productIcons } from '@/data/products';
import { getStarCount, formatStars, ghUrl } from '@/lib/github';

// Build-time star count. Cached in the module so a full build hits GitHub once.
const starLabel = formatStars(await getStarCount());
const navStarHref = ghUrl('nav-star');

const path = Astro.url.pathname;
function isActive(prefix: string) {
  return path === prefix || path.startsWith(prefix + '/');
}
const taglines: Record<string, string> = {
  downsize: 'Right-size the model per task',
  trim:     'Cut prompt bloat',
  cache:    'Find cacheable prefixes',
  script:   'Replace deterministic agents',
};
const products = productCatalog.map((p) => ({
  slug: p.slug,
  name: p.name,
  tagline: taglines[p.slug] ?? '',
  accent: p.accent,
  icon: productIcons[p.slug] ?? '',
}));
const productsActive = isActive('/products');
---
<nav class="tj-nav">
  <a href="/" class="nav-logo" aria-label="TokenJam">
    <Logo />
  </a>

  <ul class="nav-links">
    <li class="nav-products" id="nav-products">
      <button
        type="button"
        class="nav-products-toggle"
        id="nav-products-toggle"
        aria-haspopup="menu"
        aria-expanded="false"
        aria-current={productsActive ? 'page' : undefined}
      >
        Products
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3.5l3 3 3-3"/></svg>
      </button>
      <div class="nav-products-menu" role="menu" aria-labelledby="nav-products-toggle">
        {products.map((p) => (
          <a href={`/products/${p.slug}`} role="menuitem" class="nav-products-item">
            <span class="nav-products-icon" aria-hidden="true" style={`color:${p.accent}`} set:html={p.icon}></span>
            <div class="nav-products-text">
              <span class="nav-products-name" style={`color:${p.accent}`}>{p.name}</span>
              <span class="nav-products-tag">{p.tagline}</span>
            </div>
          </a>
        ))}
        <div class="nav-products-sep" aria-hidden="true"></div>
        <a href="/observe" role="menuitem" class="nav-products-item nav-products-item--observe" aria-current={isActive('/observe') ? 'page' : undefined}>
          <span class="nav-products-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </span>
          <div class="nav-products-text">
            <span class="nav-products-name">Observe</span>
            <span class="nav-products-tag">Traces, drift, alerts, schema</span>
          </div>
        </a>
      </div>
    </li>
    <li><a href="/docs" aria-current={isActive('/docs') ? 'page' : undefined}>Docs</a></li>
    <li><a href="/blog" aria-current={isActive('/blog') ? 'page' : undefined}>Blog</a></li>
    <li><a href="/about" aria-current={isActive('/about') ? 'page' : undefined}>About</a></li>
  </ul>

  <div class="nav-actions">
    <div class="theme-picker" id="theme-picker">
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Theme" aria-haspopup="menu" aria-expanded="false" title="Theme">
        <svg class="theme-icon theme-icon-system" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        <svg class="theme-icon theme-icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
        <svg class="theme-icon theme-icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <div class="theme-menu" role="menu" aria-labelledby="theme-toggle">
        <button type="button" role="menuitem" data-theme-pref="system" class="theme-menu-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          System
        </button>
        <button type="button" role="menuitem" data-theme-pref="light" class="theme-menu-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
          Light
        </button>
        <button type="button" role="menuitem" data-theme-pref="dark" class="theme-menu-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          Dark
        </button>
      </div>
    </div>
    <a
      href={navStarHref}
      target="_blank"
      rel="noopener noreferrer"
      class="nav-star"
      title="Star on GitHub"
      onclick="window.trackEvent && window.trackEvent('cta_click', 'conversion', 'star_github_nav')"
    >
      <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z"/></svg>
      <span class="nav-star-label">Star</span>
      {starLabel && <span class="nav-star-count">{starLabel}</span>}
    </a>
  </div>

  <a href="/blog" class="nav-mobile-blog" aria-current={isActive('/blog') ? 'page' : undefined}>Blog</a>
  <button type="button" class="nav-burger" id="nav-burger" aria-label="Menu" aria-expanded="false" aria-controls="nav-mobile-menu">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
  </button>
  <div class="nav-mobile-menu" id="nav-mobile-menu" role="menu">
    <div class="nav-mobile-section">Products</div>
    {products.map((p) => (
      <a href={`/products/${p.slug}`} role="menuitem">{p.name}</a>
    ))}
    <a href="/observe" role="menuitem" aria-current={isActive('/observe') ? 'page' : undefined}>Observe</a>
    <div class="nav-mobile-sep"></div>
    <a href="/docs" role="menuitem" aria-current={isActive('/docs') ? 'page' : undefined}>Docs</a>
    <a href="/blog" role="menuitem" aria-current={isActive('/blog') ? 'page' : undefined}>Blog</a>
    <a href="/about" role="menuitem" aria-current={isActive('/about') ? 'page' : undefined}>About</a>
    <a href="https://github.com/metabuilder-labs/tokenjam" target="_blank" rel="noopener noreferrer" role="menuitem">GitHub</a>
  </div>
</nav>

<script is:inline>
  (function () {
    var picker = document.getElementById('theme-picker');
    var btn = document.getElementById('theme-toggle');
    if (!picker || !btn) return;
    var media = window.matchMedia('(prefers-color-scheme: light)');
    function getPref() { try { return localStorage.getItem('tj-theme') || 'system'; } catch (e) { return 'system'; } }
    function applyTheme() {
      var pref = getPref();
      var resolved = pref === 'system' ? (media.matches ? 'light' : 'dark') : pref;
      document.documentElement.setAttribute('data-theme-pref', pref);
      if (resolved === 'light') document.documentElement.setAttribute('data-theme', 'light');
      else document.documentElement.removeAttribute('data-theme');
      picker.querySelectorAll('.theme-menu-item').forEach(function (item) {
        item.setAttribute('aria-current', item.dataset.themePref === pref ? 'true' : 'false');
      });
    }
    function setPref(pref) {
      try { localStorage.setItem('tj-theme', pref); } catch (e) {}
      if (window.trackEvent) window.trackEvent('theme_change', 'engagement', pref);
      applyTheme();
    }
    if (window.trackEvent) {
      var blogLink = document.querySelector('.nav-links a[href^="/blog"]');
      if (blogLink) blogLink.addEventListener('click', function () {
        window.trackEvent('nav_click', 'engagement', 'blog');
      });
    }
    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      var open = picker.classList.toggle('open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    picker.querySelectorAll('.theme-menu-item').forEach(function (item) {
      item.addEventListener('click', function () {
        setPref(item.dataset.themePref);
        picker.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      });
    });
    document.addEventListener('click', function (e) {
      if (!picker.contains(e.target)) {
        picker.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      }
    });
    if (media.addEventListener) media.addEventListener('change', function () { if (getPref() === 'system') applyTheme(); });
    else if (media.addListener) media.addListener(function () { if (getPref() === 'system') applyTheme(); });
    applyTheme();

    // Products dropdown
    var prod = document.getElementById('nav-products');
    var prodBtn = document.getElementById('nav-products-toggle');
    if (prod && prodBtn) {
      prodBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        var open = prod.classList.toggle('open');
        prodBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      prod.addEventListener('mouseenter', function () {
        prod.classList.add('open');
        prodBtn.setAttribute('aria-expanded', 'true');
      });
      prod.addEventListener('mouseleave', function () {
        prod.classList.remove('open');
        prodBtn.setAttribute('aria-expanded', 'false');
      });
      document.addEventListener('click', function (e) {
        if (!prod.contains(e.target)) {
          prod.classList.remove('open');
          prodBtn.setAttribute('aria-expanded', 'false');
        }
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
          prod.classList.remove('open');
          prodBtn.setAttribute('aria-expanded', 'false');
        }
      });
    }

    var burger = document.getElementById('nav-burger');
    var menu = document.getElementById('nav-mobile-menu');
    if (burger && menu) {
      burger.addEventListener('click', function (e) {
        e.stopPropagation();
        var open = menu.classList.toggle('open');
        burger.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      menu.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', function () {
          menu.classList.remove('open');
          burger.setAttribute('aria-expanded', 'false');
        });
      });
      document.addEventListener('click', function (e) {
        if (menu.classList.contains('open') && !menu.contains(e.target) && !burger.contains(e.target)) {
          menu.classList.remove('open');
          burger.setAttribute('aria-expanded', 'false');
        }
      });
    }
  })();
</script>
