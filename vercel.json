{
  "framework": "astro",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/waitlist", "destination": "/api/waitlist.js" },
    { "source": "/api/contact",  "destination": "/api/contact.js"  },
    { "source": "/sitemap.xml",  "destination": "/sitemap-index.xml" }
  ]
}
